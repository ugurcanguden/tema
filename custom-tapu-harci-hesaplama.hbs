<script>
(function(){
document.querySelectorAll('[data-open-modal]').forEach(function(trigger){
trigger.addEventListener('click',function(e){
var m=document.getElementById(this.getAttribute('data-open-modal'));
if(!m)return;
e.preventDefault();
m.classList.add('is-open');
document.body.style.overflow='hidden';
var fabItems=document.getElementById('fabItems'),fabToggle=document.getElementById('fabToggle');
if(fabItems)fabItems.classList.remove('open');
if(fabToggle)fabToggle.classList.remove('open');
});
});
// Modal kapatma: X butonu
document.querySelectorAll('[data-close-modal]').forEach(function(btn){
btn.addEventListener('click',function(){
var m=document.getElementById(this.getAttribute('data-close-modal'));
if(m)m.classList.remove('is-open');
document.body.style.overflow='';
});
});
// Overlay'e tıklayınca kapat
document.querySelectorAll('.tm-overlay').forEach(function(ov){
ov.addEventListener('click',function(e){if(e.target===this){this.classList.remove('is-open');document.body.style.overflow=''}});
});
// Escape tuşu
document.addEventListener('keydown',function(e){
if(e.key==='Escape'){document.querySelectorAll('.tm-overlay.is-open').forEach(function(m){m.classList.remove('is-open')});document.body.style.overflow=''}
});
})();
</script>

<script>
(function(){
'use strict';
var MAX_CD=100000000;
var rowCounter=0;
function gcd(a,b){while(b!==0){var t=b;b=a%b;a=t}return Math.abs(a)}
function lcm(a,b){return(Math.abs(a)/gcd(a,b))*Math.abs(b)}
function lcmAll(arr){return arr.reduce(function(acc,v){return lcm(acc,v)},1)}
function addRow(pv,pdv){rowCounter++;var div=document.createElement('div');div.className='hp-row';div.innerHTML='<span class="hp-row-num"></span><div class="hp-frac"><div class="hp-frac-f"><span class="hp-frac-lbl">Pay</span><input class="hp-frac-inp" type="number" min="1" step="1" placeholder="Örn: 1"'+(pv!==null&&pv!==''?' value="'+pv+'"':'')+'/></div><span class="hp-frac-sep">/</span><div class="hp-frac-f"><span class="hp-frac-lbl">Payda</span><input class="hp-frac-inp" type="number" min="1" step="1" placeholder="Örn: 5"'+(pdv!==null&&pdv!==''?' value="'+pdv+'"':'')+'/></div></div><button class="hp-del" type="button" title="Sil">&#x2715;</button>';div.querySelector('.hp-del').addEventListener('click',function(){if(document.querySelectorAll('#hpRows .hp-row').length>1){div.remove();updateNums()}else showHpErr('En az bir hisse satırı olmalıdır.')});div.querySelectorAll('.hp-frac-inp').forEach(function(inp){inp.addEventListener('keydown',function(e){if(e.key==='Enter')hpCalculate()})});document.getElementById('hpRows').appendChild(div);updateNums()}
function updateNums(){document.querySelectorAll('#hpRows .hp-row').forEach(function(r,i){var n=r.querySelector('.hp-row-num');if(n)n.textContent=(i+1)+'.';})}
function getData(){var shares=[];document.querySelectorAll('#hpRows .hp-row').forEach(function(r){var inp=r.querySelectorAll('.hp-frac-inp');shares.push({pay:inp[0].value.trim(),payda:inp[1].value.trim()})});return shares}
function validate(shares){if(shares.length===0)return'En az bir hisse girmelisiniz.';for(var i=0;i<shares.length;i++){var s=shares[i],n=i+1;if(s.pay==='')return n+'. hisse: Pay alanı boş bırakılamaz.';if(s.payda==='')return n+'. hisse: Payda alanı boş bırakılamaz.';var pv=parseFloat(s.pay),pdv=parseFloat(s.payda);if(isNaN(pv)||pv!==Math.floor(pv)||pv<=0)return n+'. hisse: Pay pozitif tam sayı olmalıdır.';if(isNaN(pdv)||pdv!==Math.floor(pdv)||pdv<=0)return n+'. hisse: Payda pozitif tam sayı olmalıdır (0 olamaz).'}return null}
function hpCalculate(){clearHpErr();clearHpWarn();var raw=getData();var err=validate(raw);if(err){showHpErr(err);return}var shares=raw.map(function(s){return{pay:parseInt(s.pay,10),payda:parseInt(s.payda,10)}});var denoms=shares.map(function(s){return s.payda});var cd=lcmAll(denoms);if(cd>MAX_CD)showHpWarn('Ortak payda çok büyük oluştu ('+cd.toLocaleString('tr-TR')+'). Lütfen hisseleri kontrol edin.');var norm=shares.map(function(s){var mult=cd/s.payda;return{origPay:s.pay,origPayda:s.payda,newPay:s.pay*mult,newPayda:cd,mult:mult}});var totalPay=norm.reduce(function(a,n){return a+n.newPay},0);renderHpResults(norm,cd,totalPay)}
function renderHpResults(norm,cd,totalPay){var h='';h+='<div class="hp-card-title">Payda Eşitleme Sonucu</div>';h+='<div class="hp-payda-box"><span class="hp-payda-lbl">Ortak Payda</span><span class="hp-payda-val">'+cd+'</span></div>';h+='<table class="hp-tbl"><thead><tr><th>#</th><th>Girilen</th><th class="hp-col-pay">Pay</th><th class="hp-col-payda">Payda</th><th>Çarpan</th><th>Eşitlenmiş</th></tr></thead><tbody>';norm.forEach(function(n,i){h+='<tr><td class="hp-td-n">'+(i+1)+'</td><td class="hp-td-orig">'+n.origPay+'/'+n.origPayda+'</td><td class="hp-td-mono hp-col-pay">'+n.origPay+'</td><td class="hp-td-mono hp-col-payda">'+n.origPayda+'</td><td class="hp-td-x">&#215;'+n.mult+'</td><td class="hp-td-eq">'+n.newPay+'/'+n.newPayda+'</td></tr>'});h+='</tbody></table>';var cls,msg;if(totalPay===cd){cls='hp-total-ok';msg='Girilen hisselerin toplamı<br>tam hisseye eşittir.'}else if(totalPay<cd){cls='hp-total-low';msg='Tam hisseyi tamamlamıyor.<br>Eksik: '+(cd-totalPay)+'/'+cd}else{cls='hp-total-hi';msg='Tam hisseden fazladır.<br>Fazla: '+(totalPay-cd)+'/'+cd}h+='<div class="hp-total '+cls+'"><div><div class="hp-total-sublbl">Toplam Hisse</div><div class="hp-total-frac">'+totalPay+'/'+cd+'</div></div><div class="hp-total-msg">'+msg+'</div></div>';var res=document.getElementById('hpRes');res.innerHTML=h;res.classList.add('on');document.getElementById('hpEmpty').style.display='none'}
function hpResetAll(){document.getElementById('hpRows').innerHTML='';rowCounter=0;addRow(null,null);addRow(null,null);clearHpErr();clearHpWarn();var res=document.getElementById('hpRes');res.classList.remove('on');res.innerHTML='';document.getElementById('hpEmpty').style.display='';document.getElementById('hpQiInput').value=''}
function parseQuickInput(){var text=document.getElementById('hpQiInput').value.trim();if(!text)return;var parts=text.split(',');var newShares=[];for(var i=0;i<parts.length;i++){var part=parts[i].trim();var sl=part.split('/');if(sl.length!==2||!sl[0].trim()||!sl[1].trim()||isNaN(sl[0].trim())||isNaN(sl[1].trim())){showHpErr('Hisse formatı geçersiz. Lütfen 1/5, 2/4 gibi pay/payda formatında girin.');return}newShares.push({pay:sl[0].trim(),payda:sl[1].trim()})}if(newShares.length===0){showHpErr('Hisse bulunamadı.');return}document.getElementById('hpRows').innerHTML='';rowCounter=0;clearHpErr();newShares.forEach(function(s){addRow(s.pay,s.payda)});document.getElementById('hpQiInput').value=''}
function showHpErr(m){document.getElementById('hpErrMsg').textContent=m;document.getElementById('hpErr').classList.add('on')}
function clearHpErr(){document.getElementById('hpErr').classList.remove('on')}
function showHpWarn(m){document.getElementById('hpWarnMsg').textContent=m;document.getElementById('hpWarn').classList.add('on')}
function clearHpWarn(){document.getElementById('hpWarn').classList.remove('on')}
document.getElementById('hpCalcBtn').addEventListener('click',hpCalculate);
document.getElementById('hpClearBtn').addEventListener('click',hpResetAll);
document.getElementById('hpAddBtn').addEventListener('click',function(){addRow(null,null)});
document.getElementById('hpQiBtn').addEventListener('click',parseQuickInput);
document.getElementById('hpQiInput').addEventListener('keydown',function(e){if(e.key==='Enter')parseQuickInput()});
addRow(null,null);addRow(null,null);
})();
</script>

<script>
(function(){
'use strict';
var IPOTEK_DAMGA_VERGISI_ORANI=TM.IPOTEK_DAMGA_VERGISI_ORANI;
var IPOTEK_TAPU_HARCI_ORANI=TM.IPOTEK_TAPU_HARCI_ORANI;
var YETKI_TALEPLI_CARPAN=TM.YETKI_TALEPLI_CARPAN;
function formatTL(n){return TM.formatTurkishCurrency(n)}
function formatMoneyDisplay(n){return TM.formatMoneyInput(n)}
function calculateIpotekTesisiMasraf(ipotekBedeli,harctanMuaf,donerAnaTutar,tasinmazSayisi,yetkiTalepli){
var damgaVergisi=harctanMuaf?0:ipotekBedeli*IPOTEK_DAMGA_VERGISI_ORANI;
var ipotekTapuHarci=harctanMuaf?0:ipotekBedeli*IPOTEK_TAPU_HARCI_ORANI;
var doner=TM.calculateRevolvingFundByPropertyCount(donerAnaTutar,tasinmazSayisi);
var hesaplananDonerSermaye=doner.araToplam*(yetkiTalepli?YETKI_TALEPLI_CARPAN:1);
var genelToplam=damgaVergisi+ipotekTapuHarci+hesaplananDonerSermaye;
return{ipotekBedeli:ipotekBedeli,harctanMuaf:harctanMuaf,damgaVergisi:damgaVergisi,ipotekTapuHarci:ipotekTapuHarci,donerAnaTutar:donerAnaTutar,tasinmazSayisi:tasinmazSayisi,ilaveTasinmazSayisi:doner.fazla,ilaveDonerSermaye:doner.ilave,donerAraToplam:doner.araToplam,yetkiTalepli:yetkiTalepli,hesaplananDonerSermaye:hesaplananDonerSermaye,genelToplam:genelToplam};
}
function validateMortgageInputs(){
var ipotekBedeliStr=document.getElementById('imIpotekBedeli').value.trim();
var harctanMuaf=document.getElementById('imMuaf').checked;
var anaTutarStr=document.getElementById('imAnaTutar').value.trim();
var tabsinmazStr=document.getElementById('imTabsinmaz').value.trim();
if(!harctanMuaf){
if(!ipotekBedeliStr)return'İpotek bedeli girilmelidir.';
if(!TM.isValidTurkishCurrency(ipotekBedeliStr))return'İpotek bedeli geçerli bir para formatında olmalıdır.';
var ib=TM.parseTurkishCurrency(ipotekBedeliStr);
if(ib<0)return'İpotek bedeli negatif olamaz.';
if(ib===0)return'İpotek bedeli 0\'dan büyük olmalıdır.';
}else if(ipotekBedeliStr!==''){
if(!TM.isValidTurkishCurrency(ipotekBedeliStr))return'İpotek bedeli geçerli bir para formatında olmalıdır.';
var ib2=TM.parseTurkishCurrency(ipotekBedeliStr);
if(ib2<0)return'İpotek bedeli negatif olamaz.';
}
if(!anaTutarStr)return'Döner sermaye ana tutarı girilmelidir.';
if(!TM.isValidTurkishCurrency(anaTutarStr))return'Döner sermaye ana tutarı geçerli bir para formatında olmalıdır.';
var baseAmount=TM.parseTurkishCurrency(anaTutarStr);
if(baseAmount<0)return'Döner sermaye ana tutarı negatif olamaz.';
if(baseAmount===0)return'Döner sermaye ana tutarı 0\'dan büyük olmalıdır.';
if(tabsinmazStr!==''){var tv=parseFloat(tabsinmazStr);if(isNaN(tv)||tv<1||tv!==Math.floor(tv))return'Taşınmaz sayısı 1 veya daha büyük tam sayı olmalıdır.'}
return null;
}
function resRow(lbl,val,valClass){return'<div class="ids-res-row"><span class="ids-res-lbl">'+lbl+'</span><span class="ids-res-val'+(valClass?' '+valClass:'')+'">' +val+'</span></div>'}
function idsCalculate(){
clearIdsErr();
var err=validateMortgageInputs();
if(err){showIdsErr(err);return}
var ipotekBedeli=TM.parseTurkishCurrency(document.getElementById('imIpotekBedeli').value.trim());
var harctanMuaf=document.getElementById('imMuaf').checked;
var donerAnaTutar=TM.parseTurkishCurrency(document.getElementById('imAnaTutar').value.trim());
var tabsinmazStr=document.getElementById('imTabsinmaz').value.trim();
var tasinmazSayisi=tabsinmazStr===''?1:Math.max(1,parseInt(tabsinmazStr,10));
var yetkiTalepli=document.getElementById('imYetki').checked;
var r=calculateIpotekTesisiMasraf(ipotekBedeli,harctanMuaf,donerAnaTutar,tasinmazSayisi,yetkiTalepli);
renderIdsResults(r);
}
function renderIdsResults(r){
var h='';
h+='<div class="ids-res-title">İpotek Tesisi Masraf Hesaplama Sonucu</div>';
h+='<div class="ids-res-rows">';
if(r.ipotekBedeli>0)h+=resRow('İpotek Bedeli',formatTL(r.ipotekBedeli));
h+=resRow('Harçtan Muaf',r.harctanMuaf?'<span class="ids-badge-evet">Evet</span>':'<span class="ids-badge-hayir">Hayır</span>');
if(!r.harctanMuaf){
h+=resRow('Damga Vergisi Oranı','%0,95','ids-res-val-plain');
h+=resRow('Damga Vergisi',formatTL(r.damgaVergisi));
h+=resRow('Tapu Harcı Oranı','%0,455','ids-res-val-plain');
h+=resRow('İpotek Tapu Harcı',formatTL(r.ipotekTapuHarci));
}else{
h+='<div class="ids-res-note">Harçtan muaf seçildiği için ipotek bedeli üzerinden damga vergisi ve tapu harcı hesaplanmamıştır.</div>';
}
h+='</div>';
h+='<div class="ids-res-divider"></div>';
h+='<div class="ids-res-rows">';
h+=resRow('Döner Sermaye Ana Tutarı',formatTL(r.donerAnaTutar));
h+=resRow('Taşınmaz Sayısı',r.tasinmazSayisi+' adet','ids-res-val-plain');
h+=resRow('İlave Taşınmaz Sayısı',r.ilaveTasinmazSayisi+' adet','ids-res-val-plain');
h+=resRow('İlave Döner Sermaye Oranı','%13,7854','ids-res-val-plain');
h+=resRow('İlave Döner Sermaye Tutarı',formatTL(r.ilaveDonerSermaye));
h+=resRow('Döner Sermaye Ara Toplamı',formatTL(r.donerAraToplam),'ids-res-val-em');
h+='</div>';
h+='<div class="ids-res-divider"></div>';
h+='<div class="ids-res-rows">';
if(r.yetkiTalepli){h+=resRow('Yetki Talepli İşlem','<span class="ids-badge-evet">Evet</span>');h+='<div class="ids-res-note">Yetki talepli işlem seçildiği için döner sermaye ara toplamı 2 kat uygulanmıştır.</div>'}else{h+=resRow('Yetki Talepli İşlem','<span class="ids-badge-hayir">Hayır</span>')}
h+=resRow('Hesaplanan Döner Sermaye',formatTL(r.hesaplananDonerSermaye),'ids-res-val-em');
h+='</div>';
h+='<div class="ids-grand"><span class="ids-grand-lbl">Genel Toplam</span><span class="ids-grand-val">'+formatTL(r.genelToplam)+'</span></div>';
var resEl=document.getElementById('imRes');resEl.innerHTML=h;resEl.classList.add('on');document.getElementById('imEmpty').style.display='none';
}
function idsResetAll(){
document.getElementById('imIpotekBedeli').value='';
document.getElementById('imAnaTutar').value='';
document.getElementById('imTabsinmaz').value='';
var muafCb=document.getElementById('imMuaf');muafCb.checked=false;document.getElementById('imMuafOption').classList.remove('active');
var cb=document.getElementById('imYetki');cb.checked=false;document.getElementById('imYetkiOption').classList.remove('active');
clearIdsErr();
var resEl=document.getElementById('imRes');resEl.classList.remove('on');resEl.innerHTML='';
document.getElementById('imEmpty').style.display='';
}
function showIdsErr(m){document.getElementById('imErrMsg').textContent=m;document.getElementById('imErr').classList.add('on')}
function clearIdsErr(){document.getElementById('imErr').classList.remove('on')}
document.getElementById('imCalcBtn').addEventListener('click',idsCalculate);
document.getElementById('imClearBtn').addEventListener('click',idsResetAll);
document.getElementById('imYetkiOption').addEventListener('click',function(){var cb=document.getElementById('imYetki');cb.checked=!cb.checked;this.classList.toggle('active',cb.checked)});
document.getElementById('imMuafOption').addEventListener('click',function(){var cb=document.getElementById('imMuaf');cb.checked=!cb.checked;this.classList.toggle('active',cb.checked)});
document.getElementById('imIpotekBedeli').addEventListener('blur',function(){var v=TM.parseTurkishCurrency(this.value);if(v>0)this.value=formatMoneyDisplay(v);else if(this.value.trim()!=='')this.value=''});
document.getElementById('imIpotekBedeli').addEventListener('keydown',function(e){if(e.key==='Enter')idsCalculate()});
document.getElementById('imAnaTutar').addEventListener('blur',function(){var v=TM.parseTurkishCurrency(this.value);if(v>0)this.value=formatMoneyDisplay(v);else if(this.value.trim()!=='')this.value=''});
document.getElementById('imAnaTutar').addEventListener('keydown',function(e){if(e.key==='Enter')idsCalculate()});
document.getElementById('imTabsinmaz').addEventListener('keydown',function(e){if(e.key==='Enter')idsCalculate()});
})();
</script>

<script>
(function(){
'use strict';
var SATIS_RATE_TOPLAM=0.04,BAGIS_RATE=0.06831,IPOTEK_SABIT=504.80,TASHIH_SABIT=2371.80,MAKTU_HARC=411.60,YETKI_CARPAN=TM.YETKI_TALEPLI_CARPAN,DONER_SERMAYE_ILAVE_ORANI=TM.DONER_SERMAYE_ILAVE_ORANI,AKTIF_TAKSIM_HARC_ORANI=TM.TAKSIM_HARC_ORANI;
var tabs=document.querySelectorAll('.th-tab');
var sections={satis:document.getElementById('secSatis'),bagis:document.getElementById('secBagis'),ipotek:document.getElementById('secIpotek'),intikal:document.getElementById('secIntikal'),tashih:document.getElementById('secTashih'),taksim:document.getElementById('secTaksim')};
var calcBtn=document.getElementById('thCalcBtn'),errorEl=document.getElementById('thError'),errorMsg=document.getElementById('thErrorMsg');
var emptyEl=document.getElementById('thEmpty'),resultEl=document.getElementById('thResult');
var rowsEl=document.getElementById('thResultRows'),grandEl=document.getElementById('thGrandTotal');
var splitArea=document.getElementById('thSplitArea'),maktuArea=document.getElementById('thMaktuArea');
var currentType='satis';

function fmt(n){return TM.formatTurkishCurrency(n)}
function parseMoney(v){return TM.parseTurkishCurrency(v)}
function validateMoneyField(id,label){
var value=document.getElementById(id).value.trim();
if(value!==''&&!TM.isValidTurkishCurrency(value)){showError(label+' geçerli bir para formatında olmalıdır.');return false}
return true;
}
function showError(m){errorMsg.textContent=m;errorEl.classList.add('visible')}
function hideError(){errorEl.classList.remove('visible')}
function row(l,v){return'<div class="th-result-row"><span class="th-result-label">'+l+'</span><span class="th-result-value">'+v+'</span></div>'}
function calcIlaveDoner(anaTutar,tasinmazSayisi){return TM.calculateRevolvingFundByPropertyCount(anaTutar,tasinmazSayisi)}
function calculateSalesFixedFeeDistribution(maktuHarc,oranliHarc,donerHesap,payment){
var aliciMaktu=maktuHarc/2,saticiMaktu=maktuHarc/2;
var aliciOranli=oranliHarc/2,saticiOranli=oranliHarc/2;
var aliciHarcToplami=aliciMaktu+aliciOranli,saticiHarcToplami=saticiMaktu+saticiOranli;
var bt,st;
if(payment==='buyer'){bt=maktuHarc+oranliHarc+donerHesap;st=0}
else if(payment==='seller'){bt=0;st=maktuHarc+oranliHarc+donerHesap}
else{bt=aliciHarcToplami;st=saticiHarcToplami}
return{aliciMaktu:aliciMaktu,saticiMaktu:saticiMaktu,aliciOranli:aliciOranli,saticiOranli:saticiOranli,aliciHarcToplami:aliciHarcToplami,saticiHarcToplami:saticiHarcToplami,bt:bt,st:st};
}

document.querySelectorAll('.money-input').forEach(function(el){el.addEventListener('blur',function(){var v=TM.parseTurkishCurrency(this.value);if(v>0)this.value=TM.formatMoneyInput(v);else if(this.value.trim()!=='')this.value=''})});
tabs.forEach(function(tab){tab.addEventListener('click',function(){tabs.forEach(function(t){t.classList.remove('active')});tab.classList.add('active');currentType=tab.getAttribute('data-type');Object.keys(sections).forEach(function(k){sections[k].classList.remove('visible')});sections[currentType].classList.add('visible');emptyEl.style.display='';resultEl.classList.remove('visible');hideError()})});
document.querySelectorAll('.th-toggle-group .th-toggle-option').forEach(function(opt){opt.addEventListener('click',function(){var g=opt.closest('.th-toggle-group');g.querySelectorAll('.th-toggle-option').forEach(function(o){o.classList.remove('active')});opt.classList.add('active')})});
var yetkiOption=document.getElementById('satisYetkiOption');
if(yetkiOption){yetkiOption.addEventListener('click',function(){var cb=document.getElementById('satisYetki');cb.checked=!cb.checked;yetkiOption.classList.toggle('active',cb.checked)})}
var taksimYetkiOption=document.getElementById('taksimYetkiOption');
if(taksimYetkiOption){taksimYetkiOption.addEventListener('click',function(){var cb=document.getElementById('taksimYetki');cb.checked=!cb.checked;taksimYetkiOption.classList.toggle('active',cb.checked)})}
document.querySelectorAll('.th-input').forEach(function(el){el.addEventListener('keydown',function(e){if(e.key==='Enter')calculate()})});

function calculate(){
hideError();var html='',grand=0;splitArea.innerHTML='';maktuArea.innerHTML='';

if(currentType==='satis'){
var hissedarMaktuRaw=document.getElementById('satisHissedarMaktu').value;
var hissedarMaktu=hissedarMaktuRaw===''?0:parseInt(hissedarMaktuRaw,10);
if(!validateMoneyField('satisBedelOranli','Maktuya düşmeyen toplam satış bedeli'))return;
if(!validateMoneyField('satisDoner','Döner sermaye'))return;
var bedelOranli=parseMoney(document.getElementById('satisBedelOranli').value);
var doner=parseMoney(document.getElementById('satisDoner').value);
var tasinmazRaw=document.getElementById('satisTabsinmaz').value;
var tasinmaz=tasinmazRaw===''||tasinmazRaw==='0'?1:parseInt(tasinmazRaw,10);
var yetkiSecili=document.getElementById('satisYetki').checked;
var payment=(document.querySelector('input[name="satisPayment"]:checked')||{}).value||'separate';
if(hissedarMaktu===0&&bedelOranli===0){showError('Lütfen en az bir tutar veya maktu hissedar sayısı girin.');return}
if(isNaN(hissedarMaktu)||hissedarMaktu<0){showError('Maktu harca düşen hissedar sayısı negatif olamaz.');return}
if(hissedarMaktuRaw!==''&&(parseFloat(hissedarMaktuRaw)!==Math.floor(parseFloat(hissedarMaktuRaw)))){showError('Hissedar sayısı tam sayı olmalıdır.');return}
if(bedelOranli<0||doner<0){showError('Tutar alanları negatif olamaz.');return}
if(isNaN(tasinmaz)||tasinmaz<0){showError('Taşınmaz sayısı negatif olamaz.');return}
if(tasinmazRaw!==''&&tasinmazRaw!=='0'&&(parseFloat(tasinmazRaw)!==Math.floor(parseFloat(tasinmazRaw)))){showError('Taşınmaz sayısı tam sayı olmalıdır.');return}
var maktuHarc=hissedarMaktu*MAKTU_HARC;
var oranliHarc=bedelOranli*SATIS_RATE_TOPLAM;
var ilaveDoner=calcIlaveDoner(doner,tasinmaz);
var donerAraToplam=ilaveDoner.araToplam;
var donerHesap=donerAraToplam*(yetkiSecili?YETKI_CARPAN:1);
grand=maktuHarc+oranliHarc+donerHesap;
if(hissedarMaktu>0){html+=row('Maktu Harca Düşen Hissedar Sayısı',hissedarMaktu+' kişi');html+=row('Maktu Harç Toplamı',fmt(maktuHarc))}
if(bedelOranli>0){html+=row('Maktuya Düşmeyen Toplam Satış Bedeli',fmt(bedelOranli));html+=row('Oranlı Satış Harcı Toplamı',fmt(oranliHarc))}
var dist=calculateSalesFixedFeeDistribution(maktuHarc,oranliHarc,donerHesap,payment);
if(maktuHarc>0){html+=row('Alıcı Maktu Harç Payı',fmt(dist.aliciMaktu));html+=row('Satıcı Maktu Harç Payı',fmt(dist.saticiMaktu))}
if(oranliHarc>0){html+=row('Alıcı Oranlı Harç Payı',fmt(dist.aliciOranli));html+=row('Satıcı Oranlı Harç Payı',fmt(dist.saticiOranli))}
if(maktuHarc>0||oranliHarc>0){html+=row('Alıcı Harç Toplamı',fmt(dist.aliciHarcToplami));html+=row('Satıcı Harç Toplamı',fmt(dist.saticiHarcToplami))}
if(doner>0){html+=row('Döner Sermaye Ana Tutarı',fmt(doner));if(tasinmaz>1){html+=row('Taşınmaz Sayısı',tasinmaz+' adet');html+=row('İlave Taşınmaz Sayısı',ilaveDoner.fazla+' adet');html+=row('İlave Döner Sermaye Oranı','%'+((DONER_SERMAYE_ILAVE_ORANI*100).toFixed(4).replace('.',',')));html+=row('İlave Döner Sermaye Tutarı',fmt(ilaveDoner.ilave));html+=row('Döner Sermaye Ara Toplamı',fmt(donerAraToplam))}else{html+=row('İlave Döner Sermaye Tutarı',fmt(0))}if(yetkiSecili){html+=row('Yetki Talepli İşlem','Evet — döner sermaye ara toplamı 2 kat uygulandı')}html+=row('Hesaplanan Döner Sermaye',fmt(donerHesap))}
var bt=dist.bt,st=dist.st;
var splitNote=payment==='separate'&&donerHesap>0?'<div class="th-info-inline" style="margin-top:8px"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> Döner sermaye uygulamada işlem özelinde tahsil edilir, alıcı/satıcı tutarlarına dahil değildir.</div>':'';
splitArea.innerHTML='<div class="th-split"><div class="th-split-card"><div class="th-split-role">Alıcı Öder</div><div class="th-split-amount'+(bt===0?' zero':'')+'">'+fmt(bt)+'</div></div><div class="th-split-card"><div class="th-split-role">Satıcı Öder</div><div class="th-split-amount'+(st===0?' zero':'')+'">'+fmt(st)+'</div></div></div>'+splitNote;
}

else if(currentType==='bagis'){
var bedel=parseMoney(document.getElementById('bagisBedel').value);
var doner=parseMoney(document.getElementById('bagisDoner').value);
if(!validateMoneyField('bagisBedel','Gayrimenkul değeri'))return;
if(!validateMoneyField('bagisDoner','Döner sermaye'))return;
if(bedel<=0){showError('Lütfen geçerli bir gayrimenkul değeri girin.');return}
var harc=bedel*BAGIS_RATE;grand=harc+doner;
html+=row('Bağış Harcı (%6,831)',fmt(harc));
if(doner>0)html+=row('Döner Sermaye',fmt(doner));
html+=row('Ödeyen','Alan kişi');
}

else if(currentType==='ipotek'){
var adet=parseInt(document.getElementById('ipotekAdet').value)||1;
if(!validateMoneyField('ipotekDoner','Döner sermaye'))return;
var ipotekDoner=parseMoney(document.getElementById('ipotekDoner').value);
var ipotekTabsinmazRaw=document.getElementById('ipotekTabsinmaz').value;
var ipotekTabsinmaz=ipotekTabsinmazRaw===''||ipotekTabsinmazRaw==='0'?1:parseInt(ipotekTabsinmazRaw,10);
if(isNaN(ipotekTabsinmaz)||ipotekTabsinmaz<0){showError('Taşınmaz sayısı negatif olamaz.');return}
var ipotekHarc=IPOTEK_SABIT*adet;
var ipotekIlave=calcIlaveDoner(ipotekDoner,ipotekTabsinmaz);
var ipotekDonerHesap=ipotekIlave.araToplam;
grand=ipotekHarc+ipotekDonerHesap;
html+=row('İşlem Adedi',adet+' adet');
html+=row('İşlem Başı Harç',fmt(IPOTEK_SABIT));
if(adet>1)html+=row('Toplam Sabit Harç',fmt(ipotekHarc));
if(ipotekDoner>0){html+=row('Döner Sermaye Ana Tutarı',fmt(ipotekDoner));if(ipotekIlave.fazla>0){html+=row('Taşınmaz Sayısı',ipotekTabsinmaz+' adet');html+=row('İlave Taşınmaz Sayısı',ipotekIlave.fazla+' adet');html+=row('İlave Döner Sermaye Oranı','%'+((DONER_SERMAYE_ILAVE_ORANI*100).toFixed(4).replace('.',',')));html+=row('İlave Döner Sermaye Tutarı',fmt(ipotekIlave.ilave));html+=row('Döner Sermaye Ara Toplamı',fmt(ipotekDonerHesap))}else{html+=row('İlave Döner Sermaye Tutarı',fmt(0))}html+=row('Hesaplanan Döner Sermaye',fmt(ipotekDonerHesap))}
}

else if(currentType==='intikal'){
var doner=parseMoney(document.getElementById('intikalDoner').value);
if(!validateMoneyField('intikalDoner','Döner sermaye bedeli'))return;
if(doner<=0){showError('Lütfen döner sermaye bedelini girin.');return}
grand=doner;
html+=row('Tapu Harcı',fmt(0));
html+=row('Döner Sermaye',fmt(doner));
}

else if(currentType==='tashih'){
grand=TASHIH_SABIT;
html+=row('Tashih (Düzeltme) Harcı',fmt(TASHIH_SABIT));
}

else if(currentType==='taksim'){
var taksimHissedarMaktuRaw=document.getElementById('taksimHissedarMaktu').value;
var taksimHissedarMaktu=taksimHissedarMaktuRaw===''?0:parseInt(taksimHissedarMaktuRaw,10);
var beyanDegeri=parseMoney(document.getElementById('taksimBeyanDegeri').value);
var taksimDoner=parseMoney(document.getElementById('taksimDoner').value);
if(!validateMoneyField('taksimBeyanDegeri','Maktuya düşmeyen toplam bedel'))return;
if(!validateMoneyField('taksimDoner','Döner sermaye ana tutarı'))return;
var taksimTabsinmazRaw=document.getElementById('taksimTabsinmaz').value;
var taksimTabsinmaz=taksimTabsinmazRaw===''||taksimTabsinmazRaw==='0'?1:parseInt(taksimTabsinmazRaw,10);
var taksimYetki=document.getElementById('taksimYetki').checked;
if(taksimHissedarMaktu===0&&beyanDegeri===0){showError('Lütfen en az bir tutar veya maktu hissedar sayısı girin.');return}
if(isNaN(taksimHissedarMaktu)||taksimHissedarMaktu<0){showError('Maktu harca düşen hissedar sayısı negatif olamaz.');return}
if(taksimHissedarMaktuRaw!==''&&(parseFloat(taksimHissedarMaktuRaw)!==Math.floor(parseFloat(taksimHissedarMaktuRaw)))){showError('Hissedar sayısı tam sayı olmalıdır.');return}
if(beyanDegeri<0||taksimDoner<0){showError('Tutar alanları negatif olamaz.');return}
if(isNaN(taksimTabsinmaz)||taksimTabsinmaz<0){showError('Taşınmaz sayısı negatif olamaz.');return}
if(taksimTabsinmazRaw!==''&&taksimTabsinmazRaw!=='0'&&(parseFloat(taksimTabsinmazRaw)!==Math.floor(parseFloat(taksimTabsinmazRaw)))){showError('Taşınmaz sayısı tam sayı olmalıdır.');return}
var taksimMaktuHarc=taksimHissedarMaktu*MAKTU_HARC;
var taksimHarc=beyanDegeri*AKTIF_TAKSIM_HARC_ORANI;
var taksimIlave=calcIlaveDoner(taksimDoner,taksimTabsinmaz);
var taksimDonerAraToplam=taksimIlave.araToplam;
var taksimDonerHesap=taksimDonerAraToplam*(taksimYetki?YETKI_CARPAN:1);
grand=taksimMaktuHarc+taksimHarc+taksimDonerHesap;
if(taksimHissedarMaktu>0){html+=row('Maktu Harca Düşen Hissedar Sayısı',taksimHissedarMaktu+' kişi');html+=row('Maktu Harç Toplamı',fmt(taksimMaktuHarc))}
if(beyanDegeri>0){html+=row('Maktuya Düşmeyen Toplam Bedel',fmt(beyanDegeri));html+=row('Taksim Harcı Oranı','%2,277');html+=row('Taksim Tapu Harcı',fmt(taksimHarc))}
if(taksimDoner>0||taksimTabsinmaz>1){html+=row('Döner Sermaye Ana Tutarı',fmt(taksimDoner));if(taksimDoner>0&&taksimTabsinmaz>1){html+=row('Taşınmaz Sayısı',taksimTabsinmaz+' adet');html+=row('İlave Taşınmaz Sayısı',taksimIlave.fazla+' adet');html+=row('İlave Döner Sermaye Oranı','%'+((DONER_SERMAYE_ILAVE_ORANI*100).toFixed(4).replace('.',',')));html+=row('İlave Döner Sermaye Tutarı',fmt(taksimIlave.ilave));html+=row('Döner Sermaye Ara Toplamı',fmt(taksimDonerAraToplam))}else{html+=row('İlave Döner Sermaye Tutarı',fmt(0))}if(taksimYetki&&taksimDonerAraToplam>0){html+=row('Yetki Talepli İşlem','Evet — döner sermaye ara toplamı 2 kat uygulandı')}html+=row('Hesaplanan Döner Sermaye',fmt(taksimDonerHesap))}
}

rowsEl.innerHTML=html;grandEl.textContent=fmt(grand);
emptyEl.style.display='none';resultEl.classList.remove('visible');
void resultEl.offsetWidth;resultEl.classList.add('visible');
}
calcBtn.addEventListener('click',calculate);
})();
</script>
