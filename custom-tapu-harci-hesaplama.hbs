{{!< default}}
{{> "tm-money-utils"}}
<style>
.th-page *,.th-page *::before,.th-page *::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#1E3A5F;--navy-dark:#142840;--navy-light:#2a4f7c;--gold:#C8A24A;--gold-light:#debb6e;--surface:#fff;--surface-2:#f7f9fc;--surface-3:#eef2f7;--border:#dde3ec;--text-1:#0f1c2e;--text-2:#3d5068;--text-3:#7a90a8;--radius-sm:8px;--radius-md:14px;--radius-lg:22px;--shadow-md:0 8px 28px rgba(15,28,46,.10);--transition:.18s ease;--font-sans:'Inter',system-ui,-apple-system,sans-serif;--font-mono:'JetBrains Mono','Fira Code',monospace}
.th-page{font-family:var(--font-sans);background:var(--surface-2);min-height:100vh;color:var(--text-1)}
.th-hero{background:linear-gradient(135deg,var(--navy-dark),var(--navy) 55%,var(--navy-light));padding:56px 24px 52px;text-align:center;position:relative;overflow:hidden}
.th-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 20%,rgba(200,162,74,.13),transparent 70%),radial-gradient(ellipse 40% 60% at 20% 80%,rgba(200,162,74,.08),transparent 60%);pointer-events:none}
.th-hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(200,162,74,.18);border:1px solid rgba(200,162,74,.35);border-radius:99px;padding:5px 14px;font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--gold-light);margin-bottom:20px}
.th-hero h1{font-size:clamp(26px,5vw,42px);font-weight:800;color:#fff;line-height:1.15;letter-spacing:-.02em;margin-bottom:14px}.th-hero h1 span{color:var(--gold)}
.th-hero p{font-size:16px;color:rgba(255,255,255,.72);max-width:520px;margin:0 auto;line-height:1.6}
.th-container{max-width:960px;margin:0 auto;padding:0 20px 64px}
.th-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px}
.th-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow-md)}
.th-card-title{font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-3);margin-bottom:22px;display:flex;align-items:center;gap:8px}
.th-card-title::before{content:'';width:3px;height:14px;background:var(--gold);border-radius:2px}
.th-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-top:20px;max-width:960px;margin-left:auto;margin-right:auto;padding:0 20px}
.th-tab{padding:8px 16px;border-radius:99px;font-size:13px;font-weight:600;border:1.5px solid var(--border);background:var(--surface);color:var(--text-2);cursor:pointer;transition:all var(--transition);white-space:nowrap;display:flex;align-items:center;gap:6px}
.th-tab:hover{border-color:var(--navy-light);background:var(--surface-3)}
.th-tab.active{border-color:var(--navy);background:var(--navy);color:#fff}
.th-tab.active svg{fill:#fff}.th-tab svg{width:14px;height:14px;fill:var(--text-3);transition:fill var(--transition)}
.th-tool-actions{max-width:960px;margin:20px auto 0;padding:0 20px;display:grid;grid-template-columns:1fr 1fr;gap:12px}
.th-tool-action{width:100%;display:flex;align-items:center;gap:14px;text-align:left;padding:16px 18px;border:1.5px solid var(--border);border-radius:var(--radius-md);background:var(--surface);color:var(--text-1);cursor:pointer;box-shadow:0 3px 12px rgba(15,28,46,.07);transition:transform var(--transition),border-color var(--transition),box-shadow var(--transition)}
.th-tool-action:hover{transform:translateY(-1px);border-color:var(--navy-light);box-shadow:0 7px 20px rgba(15,28,46,.12)}
.th-tool-action-icon{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(30,58,95,.08);color:var(--navy)}
.th-tool-action-icon svg{width:19px;height:19px;fill:currentColor}
.th-tool-action-copy{display:flex;flex-direction:column;gap:3px}
.th-tool-action-title{font-size:14px;font-weight:750;line-height:1.35}
.th-tool-action-sub{font-size:12px;color:var(--text-3);line-height:1.4}
.th-field{margin-bottom:16px}.th-label{display:block;font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:7px}.th-label-hint{font-weight:400;color:var(--text-3)}
.th-input-wrap{position:relative}.th-input-prefix{position:absolute;left:14px;top:50%;transform:translateY(-50%);font-size:14px;font-weight:700;color:var(--text-3);pointer-events:none;font-family:var(--font-mono)}
.th-input{width:100%;height:48px;border:1.5px solid var(--border);border-radius:var(--radius-md);padding:0 14px 0 36px;font-size:15px;font-family:var(--font-mono);font-weight:600;color:var(--text-1);background:var(--surface);outline:none;-webkit-appearance:none;transition:border-color var(--transition),box-shadow var(--transition)}
.th-input:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,58,95,.10)}
.th-input::placeholder{color:var(--text-3);font-weight:400;font-family:var(--font-sans)}
.th-input.no-prefix{padding-left:14px}
.th-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.th-toggle-group{display:flex;flex-direction:column;gap:8px;margin-top:4px}
.th-toggle-option{display:flex;align-items:center;gap:10px;padding:11px 14px;border:1.5px solid var(--border);border-radius:var(--radius-md);cursor:pointer;transition:border-color var(--transition),background var(--transition);user-select:none}
.th-toggle-option:hover{border-color:var(--navy-light);background:var(--surface-3)}
.th-toggle-option input[type="radio"]{display:none}
.th-toggle-dot{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:border-color var(--transition)}
.th-toggle-dot::after{content:'';width:8px;height:8px;border-radius:50%;background:transparent;transition:background var(--transition)}
.th-toggle-option.active{border-color:var(--navy);background:rgba(30,58,95,.04)}
.th-toggle-option.active .th-toggle-dot{border-color:var(--navy)}
.th-toggle-option.active .th-toggle-dot::after{background:var(--navy)}
.th-toggle-text{font-size:13.5px;font-weight:500;color:var(--text-2);line-height:1.3}
.th-info-inline{display:flex;align-items:flex-start;gap:8px;padding:10px 12px;background:rgba(200,162,74,.06);border:1px solid rgba(200,162,74,.18);border-radius:var(--radius-sm);font-size:12px;color:var(--text-2);line-height:1.5;margin-top:12px}
.th-info-inline svg{flex-shrink:0;margin-top:1px}
.th-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;height:52px;margin-top:20px;border:none;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--navy),var(--navy-light));color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:transform var(--transition),box-shadow var(--transition);box-shadow:0 4px 16px rgba(30,58,95,.28);letter-spacing:.02em}
.th-btn:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(30,58,95,.36)}.th-btn:active{transform:translateY(0)}
.th-error{display:none;align-items:center;gap:8px;background:#fff5f5;border:1px solid #fecaca;border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;font-weight:500;color:#b91c1c;margin-top:12px}
.th-error.visible{display:flex}
.th-empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;text-align:center;color:var(--text-3);gap:12px;min-height:260px}
.th-empty-icon{width:52px;height:52px;background:var(--surface-3);border-radius:50%;display:flex;align-items:center;justify-content:center}
.th-empty-state p{font-size:14px;line-height:1.5;max-width:200px}
.th-result-card{display:none;flex-direction:column}.th-result-card.visible{display:flex;animation:slideIn .28s ease}
@keyframes slideIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.th-result-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--surface-3)}.th-result-row:last-child{border-bottom:none}
.th-result-label{font-size:13.5px;color:var(--text-2);font-weight:500}
.th-result-value{font-size:14px;font-weight:700;color:var(--text-1);font-family:var(--font-mono);letter-spacing:-.01em}
.th-grand-total{background:linear-gradient(135deg,var(--navy-dark),var(--navy));border-radius:var(--radius-md);padding:18px 20px;display:flex;justify-content:space-between;align-items:center;margin:16px 0}
.th-grand-total-label{font-size:14px;font-weight:600;color:rgba(255,255,255,.8)}
.th-grand-total-value{font-size:22px;font-weight:800;color:var(--gold);font-family:var(--font-mono);letter-spacing:-.02em}
.th-split{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px}
.th-split-card{background:var(--surface-2);border:1px solid var(--border);border-radius:var(--radius-md);padding:14px 16px;text-align:center}
.th-split-role{font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text-3);margin-bottom:6px}
.th-split-amount{font-size:17px;font-weight:800;color:var(--navy);font-family:var(--font-mono);letter-spacing:-.02em}
.th-split-amount.zero{color:var(--text-3);font-weight:600}
.th-maktu-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(200,162,74,.1);border:1px solid rgba(200,162,74,.25);border-radius:6px;padding:4px 10px;font-size:12px;font-weight:600;color:var(--gold);margin-top:8px}
.th-disclaimer{margin-top:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 24px;box-shadow:0 2px 8px rgba(15,28,46,.07)}
.th-disclaimer-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.th-disclaimer-head span{font-size:13px;font-weight:700;color:var(--text-2)}
.th-disclaimer p{font-size:13px;color:var(--text-3);line-height:1.7}
.th-section{display:none}.th-section.visible{display:block}
@media(max-width:700px){.th-hero{padding:44px 20px 48px}.th-tool-actions{grid-template-columns:1fr}.th-grid{grid-template-columns:1fr}.th-card{padding:22px 18px}.th-grand-total-value{font-size:18px}.th-tabs{gap:5px}.th-tab{padding:7px 12px;font-size:12px}.th-row{gap:8px}}
@media(prefers-reduced-motion:reduce){.th-result-card.visible{animation:none}.th-btn{transition:none}}
</style>

<div class="th-page">
<div class="th-hero">
<div class="th-hero-badge"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" fill="currentColor" opacity=".7"/></svg> Bilgilendirme Aracı</div>
<h1>Tapu Harcı <span>Hesaplama</span></h1>
<p>İşlem türünü seçin, harcınızı ve masraflarınızı anında hesaplayın.</p>
</div>

<div class="th-tool-actions" aria-label="Diğer hesaplama araçları">
<button class="th-tool-action" type="button" data-open-modal="modal-hisse-payda">
<span class="th-tool-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 5C7 6.1 6.1 7 5 7C3.9 7 3 6.1 3 5C3 3.9 3.9 3 5 3C6.1 3 7 3.9 7 5ZM21 19C21 20.1 20.1 21 19 21C17.9 21 17 20.1 17 19C17 17.9 17.9 17 19 17C20.1 17 21 17.9 21 19ZM5.41 3L20 18.59L18.59 20L4 4.41L5.41 3Z"/></svg></span>
<span class="th-tool-action-copy"><span class="th-tool-action-title">Hisse Payda Eşitleme</span><span class="th-tool-action-sub">Ortak paydaya dönüştürme aracı</span></span>
</button>
<button class="th-tool-action" type="button" data-open-modal="modal-ipotek">
<span class="th-tool-action-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3L2 9H4V20H20V9H22L12 3ZM18 18H6V10.08L12 6.27L18 10.08V18ZM10 18V13H14V18H10Z"/></svg></span>
<span class="th-tool-action-copy"><span class="th-tool-action-title">İpotek Tesisi Masraf Hesaplama</span><span class="th-tool-action-sub">İpotek bedeli, damga vergisi, harç ve döner sermaye</span></span>
</button>
</div>

<div class="th-tabs" id="thTabs">
<button class="th-tab active" data-type="satis"><svg viewBox="0 0 24 24"><path d="M3 11L12 4L21 11V20A1 1 0 0120 21H4A1 1 0 013 20V11Z"/></svg> Satış</button>
<button class="th-tab" data-type="bagis"><svg viewBox="0 0 24 24"><path d="M12 21.35L10.55 20.03C5.4 15.36 2 12.27 2 8.5C2 5.41 4.42 3 7.5 3C9.24 3 10.91 3.81 12 5.08C13.09 3.81 14.76 3 16.5 3C19.58 3 22 5.41 22 8.5C22 12.27 18.6 15.36 13.45 20.03L12 21.35Z"/></svg> Bağış</button>
<button class="th-tab" data-type="ipotek"><svg viewBox="0 0 24 24"><path d="M18 8H17V6A5 5 0 007 6V8H6A2 2 0 004 10V20A2 2 0 006 22H18A2 2 0 0020 20V10A2 2 0 0018 8ZM12 17A2 2 0 1114 15 2 2 0 0112 17ZM15 8H9V6A3 3 0 0115 6V8Z"/></svg> İpotek Terkini</button>
<button class="th-tab" data-type="intikal"><svg viewBox="0 0 24 24"><path d="M14 2H6A2 2 0 004 4V20A2 2 0 006 22H18A2 2 0 0020 20V8L14 2ZM16 18H8V16H16V18ZM16 14H8V12H16V14ZM13 9V3.5L18.5 9H13Z"/></svg> İntikal</button>
<button class="th-tab" data-type="tashih"><svg viewBox="0 0 24 24"><path d="M3 17.25V21H6.75L17.81 9.94L14.06 6.19L3 17.25ZM20.71 7.04A1 1 0 0020.71 5.63L18.37 3.29A1 1 0 0016.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z"/></svg> Tashih</button>
<button class="th-tab" data-type="taksim"><svg viewBox="0 0 24 24"><path d="M4 3H10V21H4V3ZM14 3H20V21H14V3Z"/></svg> Taksim İşlemi</button>
</div>

<div class="th-container">
<div class="th-grid">
<div class="th-card">
<div class="th-card-title">Bilgileri Girin</div>

<div class="th-section visible" id="secSatis">
<div class="th-field"><label class="th-label">Maktu Harca Düşen Hissedar Sayısı <span class="th-label-hint">(opsiyonel)</span></label><input class="th-input no-prefix" id="satisHissedarMaktu" type="number" min="0" step="1" placeholder="Örn: 3" autocomplete="off"/></div>
<div class="th-field"><label class="th-label">Maktuya Düşmeyen Toplam Satış Bedeli <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="satisBedelOranli" type="text" inputmode="decimal" placeholder="Örn: 1.500.000" autocomplete="off"/></div></div>
<div class="th-field"><label class="th-label">Döner Sermaye <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="satisDoner" type="text" inputmode="decimal" placeholder="1.500" autocomplete="off"/></div></div>
<div class="th-field"><label class="th-label">Taşınmaz Sayısı <span class="th-label-hint">(opsiyonel)</span></label><input class="th-input no-prefix" id="satisTabsinmaz" type="number" min="1" step="1" placeholder="1" autocomplete="off"/></div>
<div class="th-field"><label class="th-label">Yetki Talepli İşlem</label><label class="th-toggle-option" id="satisYetkiOption" style="margin-top:4px"><input type="checkbox" id="satisYetki" style="display:none"/><span class="th-toggle-dot"></span><span class="th-toggle-text">Yetki talepli işlem <span class="th-label-hint">— seçiliyse döner sermaye bedeli 2 kat hesaplanır</span></span></label></div>
<div class="th-field"><label class="th-label">Masrafı Kim Ödeyecek?</label>
<div class="th-toggle-group"><label class="th-toggle-option active"><input type="radio" name="satisPayment" value="separate" checked/><span class="th-toggle-dot"></span><span class="th-toggle-text">Alıcı ve satıcı ayrı ayrı ödesin</span></label><label class="th-toggle-option"><input type="radio" name="satisPayment" value="buyer"/><span class="th-toggle-dot"></span><span class="th-toggle-text">Tüm masrafı alıcı ödesin</span></label><label class="th-toggle-option"><input type="radio" name="satisPayment" value="seller"/><span class="th-toggle-dot"></span><span class="th-toggle-text">Tüm masrafı satıcı ödesin</span></label></div></div>
<div class="th-info-inline"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> Maktu harca düşen hissedarlar için kişi başı 411,60 TL harç hesaplanır. Maktuya düşmeyen toplam satış bedeli için ayrıca %4 oranında tapu harcı hesaplanır. Yetki talepli işlem seçilirse döner sermaye bedeli 2 kat uygulanır. Maktu harç toplamı alıcı ve satıcı arasında eşit paylaştırılır. Döner sermaye ayrıca hesaplanır.</div>
</div>

<div class="th-section" id="secBagis">
<div class="th-field"><label class="th-label">Gayrimenkul Değeri</label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="bagisBedel" type="text" inputmode="decimal" placeholder="2.000.000" autocomplete="off"/></div></div>
<div class="th-field"><label class="th-label">Döner Sermaye <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="bagisDoner" type="text" inputmode="decimal" placeholder="1.500" autocomplete="off"/></div></div>
<div class="th-info-inline"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> Bağış harcı %6,831 oranında hesaplanır ve alan kişi tarafından ödenir.</div>
</div>

<div class="th-section" id="secIpotek">
<div class="th-field"><label class="th-label">İşlem Adedi</label><input class="th-input no-prefix" id="ipotekAdet" type="number" min="1" value="1"/></div>
<div class="th-field"><label class="th-label">Döner Sermaye <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="ipotekDoner" type="text" inputmode="decimal" placeholder="1.500" autocomplete="off"/></div></div>
<div class="th-field"><label class="th-label">Taşınmaz Sayısı <span class="th-label-hint">(opsiyonel)</span></label><input class="th-input no-prefix" id="ipotekTabsinmaz" type="number" min="1" step="1" placeholder="1" autocomplete="off"/></div>
<div class="th-info-inline"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> Her bir ipotek terkini işlemi için 504,80 ₺ sabit harç alınır. Taşınmaz sayısına göre ilave döner sermaye hesaplanır.</div>
</div>

<div class="th-section" id="secIntikal">
<div class="th-field"><label class="th-label">Döner Sermaye Bedeli <span class="th-label-hint">(tapu müdürlüğünüze göre değişir)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="intikalDoner" type="text" inputmode="decimal" placeholder="1.500" autocomplete="off"/></div></div>
<div class="th-info-inline"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> İntikal (miras) işlemlerinde tapu harcı alınmaz, sadece döner sermaye bedeli ödenir. Taşınmaz sayısı tutarı değiştirmez.</div>
</div>

<div class="th-section" id="secTashih">
<div class="th-info-inline"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="#C8A24A" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="#C8A24A" stroke-width="1.2" stroke-linecap="round"/></svg> Tashih (düzeltme) işlemlerinde sabit 2.371,80 ₺ harç alınır.</div>
</div>

<div class="th-section" id="secTaksim">
<div class="th-field"><label class="th-label">Maktu Harca Düşen Hissedar Sayısı <span class="th-label-hint">(opsiyonel)</span></label><input class="th-input no-prefix" id="taksimHissedarMaktu" type="number" min="0" step="1" placeholder="Örn: 3" autocomplete="off"/></div>
<div class="th-field"><label class="th-label">Maktuya Düşmeyen Toplam Bedel <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="taksimBeyanDegeri" type="text" inputmode="decimal" placeholder="Örn: 2.500.000" autocomplete="off"/></div></div>
<div class="th-field"><label class="th-label">Döner Sermaye Ana Tutarı <span class="th-label-hint">(opsiyonel)</span></label><div class="th-input-wrap"><span class="th-input-prefix">₺</span><input class="th-input money-input" id="taksimDoner" type="text" inputmode="decimal" placeholder="Örn: 5.000" autocomplete="off"/></div></div>
