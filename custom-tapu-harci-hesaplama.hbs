.ids-input{width:100%;height:46px;border:none;outline:none;padding:0 14px;font-size:15px;font-weight:600;color:var(--text-1);background:transparent;font-family:var(--font-mono)}
.ids-input::placeholder{color:var(--text-3);font-weight:400;font-family:var(--font-sans);font-size:14px}
.ids-no-prefix{height:46px;border:1.5px solid var(--border);border-radius:var(--radius-md);padding:0 14px;font-size:15px;font-weight:600;color:var(--text-1);background:var(--surface);outline:none;-webkit-appearance:none;width:100%}
.ids-no-prefix:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,58,95,.10)}
.ids-no-prefix::placeholder{color:var(--text-3);font-weight:400;font-family:var(--font-sans);font-size:14px}
.ids-toggle{display:flex;align-items:center;gap:10px;cursor:pointer;padding:10px 12px;border-radius:var(--radius-sm);border:1.5px solid var(--border)}
.ids-toggle.active{border-color:var(--navy);background:rgba(30,58,95,.04)}
.ids-toggle-dot{width:18px;height:18px;border-radius:50%;border:2px solid var(--border);background:var(--surface);flex-shrink:0}
.ids-toggle.active .ids-toggle-dot{background:var(--navy);border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,58,95,.12)}
.ids-toggle-txt{font-size:13.5px;color:var(--text-2);line-height:1.4}
.ids-toggle.active .ids-toggle-txt{color:var(--text-1)}
.ids-err{display:none;align-items:center;gap:8px;background:#fff5f5;border:1px solid #fecaca;border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;font-weight:500;color:#b91c1c;margin-bottom:16px}
.ids-err.on{display:flex}
.ids-btns{display:flex;gap:8px;margin-bottom:16px}
.ids-calc{flex:1;height:50px;border:none;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--navy),var(--navy-light));color:#fff;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(30,58,95,.28);display:flex;align-items:center;justify-content:center;gap:8px}
.ids-calc:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(30,58,95,.36)}.ids-calc:active{transform:translateY(0)}
.ids-clear{height:50px;padding:0 18px;border:1.5px solid var(--border);border-radius:var(--radius-md);background:var(--surface);color:var(--text-2);font-size:14px;font-weight:600;cursor:pointer;flex-shrink:0}
.ids-clear:hover{border-color:var(--navy-light);color:var(--navy)}
.ids-info{display:flex;align-items:flex-start;gap:8px;padding:12px 14px;background:rgba(200,162,74,.06);border:1px solid rgba(200,162,74,.18);border-radius:var(--radius-sm);font-size:12px;color:var(--text-2);line-height:1.6}
.ids-info svg{flex-shrink:0;margin-top:1px}
.ids-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;text-align:center;color:var(--text-3);gap:12px;min-height:300px}
.ids-empty-icon{width:52px;height:52px;background:var(--surface-3);border-radius:50%;display:flex;align-items:center;justify-content:center}
.ids-empty p{font-size:14px;line-height:1.5;max-width:200px}
.ids-res{display:none;flex-direction:column}.ids-res.on{display:flex;animation:idsIn .28s ease}
@keyframes idsIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.ids-res-title{font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-3);margin-bottom:16px;display:flex;align-items:center;gap:8px}
.ids-res-title::before{content:'';width:3px;height:14px;background:var(--gold);border-radius:2px}
.ids-res-rows{display:flex;flex-direction:column;gap:0}
.ids-res-row{display:flex;justify-content:space-between;align-items:baseline;gap:12px;padding:8px 0;border-bottom:1px solid var(--surface-3)}
.ids-res-row:last-child{border-bottom:none}
.ids-res-lbl{font-size:13px;color:var(--text-2);flex-shrink:0;max-width:55%}
.ids-res-val{font-size:13px;font-weight:700;color:var(--text-1);font-family:var(--font-mono);text-align:right}
.ids-res-val-em{color:var(--navy)}
.ids-res-val-plain{font-family:var(--font-sans);font-weight:600}
.ids-res-divider{height:1px;background:var(--surface-3);margin:10px 0}
.ids-res-note{font-size:12px;color:var(--text-2);background:rgba(200,162,74,.06);border:1px solid rgba(200,162,74,.18);border-radius:var(--radius-sm);padding:8px 12px;margin:6px 0;line-height:1.5}
.ids-badge-evet{display:inline-block;font-family:var(--font-sans);font-size:12px;font-weight:700;padding:2px 8px;border-radius:99px;background:rgba(30,58,95,.08);color:var(--navy)}
.ids-badge-hayir{display:inline-block;font-family:var(--font-sans);font-size:12px;font-weight:600;padding:2px 8px;border-radius:99px;background:var(--surface-3);color:var(--text-3)}
.ids-grand{display:flex;justify-content:space-between;align-items:center;background:linear-gradient(135deg,var(--navy-dark),var(--navy));border-radius:var(--radius-md);padding:14px 18px;margin-top:10px}
.ids-grand-lbl{font-size:13px;font-weight:600;color:rgba(255,255,255,.75)}
.ids-grand-val{font-size:22px;font-weight:800;color:var(--gold);font-family:var(--font-mono);letter-spacing:-.02em}
.ids-disc{margin-top:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 24px;box-shadow:0 2px 8px rgba(15,28,46,.07)}
.ids-disc-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.ids-disc-head span{font-size:13px;font-weight:700;color:var(--text-2)}
.ids-disc p{font-size:13px;color:var(--text-3);line-height:1.7}
@media(max-width:700px){.ids-grid{grid-template-columns:1fr}.ids-card{padding:22px 18px}.ids-grand-val{font-size:18px}.ids-btns{flex-direction:column}.ids-clear{width:100%}}
</style>

