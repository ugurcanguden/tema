{{!< default}}
{{#post}}

<style>
.ka-page *, .ka-page *::before, .ka-page *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:       #1E3A5F;
    --navy-dark:  #142840;
    --navy-light: #2a4f7c;
    --gold:       #C8A24A;
    --gold-light: #debb6e;
    --surface:    #ffffff;
    --surface-2:  #f7f9fc;
    --surface-3:  #eef2f7;
    --border:     #dde3ec;
    --text-1:     #0f1c2e;
    --text-2:     #3d5068;
    --text-3:     #7a90a8;
    --green:      #16a34a;
    --green-bg:   #f0fdf4;
    --green-bdr:  #bbf7d0;
    --radius-sm:  8px;
    --radius-md:  14px;
    --radius-lg:  22px;
    --shadow-sm:  0 2px 8px rgba(15,28,46,.07);
    --shadow-md:  0 8px 28px rgba(15,28,46,.10);
    --transition: .18s ease;
    --font-sans:  'Inter', system-ui, -apple-system, sans-serif;
    --font-mono:  'JetBrains Mono', 'Fira Code', monospace;
  }

  .ka-page {
    font-family: var(--font-sans);
    background: var(--surface-2);
    min-height: 100vh;
    color: var(--text-1);
  }

  /* ── Hero ──────────────────────────────────── */
  .ka-hero {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, var(--navy-light) 100%);
    padding: 56px 24px 52px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ka-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 80% 20%, rgba(200,162,74,.13) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 20% 80%, rgba(200,162,74,.08) 0%, transparent 60%);
    pointer-events: none;
  }

  .ka-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(200,162,74,.18);
    border: 1px solid rgba(200,162,74,.35);
    border-radius: 99px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 20px;
  }

  .ka-hero h1 {
    font-size: clamp(26px, 5vw, 42px);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: -.02em;
    margin-bottom: 14px;
  }

  .ka-hero h1 span { color: var(--gold); }

  .ka-hero p {
    font-size: 16px;
    color: rgba(255,255,255,.72);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Current rate banner ───────────────────── */
  .ka-rate-banner {
    max-width: 960px;
    margin: -22px auto 0;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  .ka-rate-banner-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 16px 24px;
    box-shadow: var(--shadow-md);
  }

  .ka-rate-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }

  .ka-rate-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-2);
  }

  .ka-rate-text strong {
    color: var(--navy);
    font-family: var(--font-mono);
    font-weight: 800;
    font-size: 16px;
  }

  .ka-rate-date {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
  }

  /* ── Container ─────────────────────────────── */
  .ka-container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px 64px;
  }

  .ka-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }

  /* ── Cards ──────────────────────────────────── */
  .ka-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-md);
  }

  .ka-card-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ka-card-title::before {
    content: '';
    width: 3px;
    height: 14px;
    background: var(--gold);
    border-radius: 2px;
  }

  /* ── Form ───────────────────────────────────── */
  .ka-field { margin-bottom: 18px; }
  .ka-field:last-of-type { margin-bottom: 0; }

  .ka-label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-2);
    margin-bottom: 7px;
  }

  .ka-input-wrap { position: relative; }

  .ka-input-prefix {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    font-weight: 700;
    color: var(--text-3);
    pointer-events: none;
    font-family: var(--font-mono);
  }

  .ka-input {
    width: 100%;
    height: 48px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0 14px 0 36px;
    font-size: 15px;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--text-1);
    background: var(--surface);
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
    -webkit-appearance: none;
  }

  .ka-input:focus {
    border-color: var(--navy);
    box-shadow: 0 0 0 3px rgba(30,58,95,.10);
  }

  .ka-input::placeholder {
    color: var(--text-3);
    font-weight: 400;
    font-family: var(--font-sans);
  }

  .ka-select {
    width: 100%;
    height: 48px;
    border: 1.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 0 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-1);
    background: var(--surface);
    outline: none;
    cursor: pointer;
    -webkit-appearance: none;
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237a90a8' stroke-width='1.8' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    background-size: 12px;
    transition: border-color var(--transition);
  }

  .ka-select:focus { border-color: var(--navy); }

  /* ── Selected rate display ─────────────────── */
  .ka-selected-rate {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    padding: 8px 12px;
    background: rgba(200,162,74,.08);
    border: 1px solid rgba(200,162,74,.2);
    border-radius: var(--radius-sm);
  }

  .ka-selected-rate-label {
    font-size: 12px;
    color: var(--text-3);
    font-weight: 500;
  }

  .ka-selected-rate-value {
    font-size: 14px;
    font-weight: 800;
    color: var(--navy);
    font-family: var(--font-mono);
  }

  /* ── Button ────────────────────────────────── */
  .ka-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 52px;
    margin-top: 24px;
    border: none;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 4px 16px rgba(30,58,95,.28);
    letter-spacing: .02em;
  }

  .ka-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(30,58,95,.36);
  }

  .ka-btn:active { transform: translateY(0); }

  .ka-btn svg { flex-shrink: 0; }

  .ka-error {
    display: none;
    align-items: center;
    gap: 8px;
    background: #fff5f5;
    border: 1px solid #fecaca;
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 500;
    color: #b91c1c;
    margin-top: 12px;
  }

  .ka-error.visible { display: flex; }

  /* ── Result card ───────────────────────────── */
  .ka-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    text-align: center;
    color: var(--text-3);
    gap: 12px;
    min-height: 260px;
  }

  .ka-empty-icon {
    width: 52px;
    height: 52px;
    background: var(--surface-3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ka-empty-state p {
    font-size: 14px;
    line-height: 1.5;
    max-width: 200px;
  }

  .ka-result-card {
    display: none;
    flex-direction: column;
    gap: 0;
  }

  .ka-result-card.visible {
    display: flex;
    animation: kaSlideIn .28s ease;
  }

  @keyframes kaSlideIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── New rent highlight ────────────────────── */
  .ka-new-rent {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
    border-radius: var(--radius-md);
    padding: 22px 20px;
    text-align: center;
    margin-bottom: 16px;
  }

  .ka-new-rent-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(255,255,255,.6);
    margin-bottom: 6px;
  }

  .ka-new-rent-value {
    font-size: 28px;
    font-weight: 800;
    color: var(--gold);
    font-family: var(--font-mono);
    letter-spacing: -.02em;
  }

  /* ── Detail rows ───────────────────────────── */
  .ka-result-rows {
    display: flex;
    flex-direction: column;
  }

  .ka-result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--surface-3);
  }

  .ka-result-row:last-child { border-bottom: none; }

  .ka-result-label {
    font-size: 13.5px;
    color: var(--text-2);
    font-weight: 500;
  }

  .ka-result-value {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-1);
    font-family: var(--font-mono);
    letter-spacing: -.01em;
  }

  /* ── Increase badge ────────────────────────── */
  .ka-increase-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--green-bg);
    border: 1px solid var(--green-bdr);
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 12px;
    font-weight: 700;
    color: var(--green);
    font-family: var(--font-mono);
  }

  /* ── Disclaimer ────────────────────────────── */
  .ka-disclaimer {
    margin-top: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    box-shadow: var(--shadow-sm);
  }

  .ka-disclaimer-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .ka-disclaimer-head span {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-2);
  }

  .ka-disclaimer p {
    font-size: 13px;
    color: var(--text-3);
    line-height: 1.7;
  }

  /* ── Loading ───────────────────────────────── */
  .ka-loading {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    font-size: 13px;
    color: var(--text-3);
  }

  .ka-loading.visible { display: flex; }

  .ka-loading-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--navy);
    animation: bounce .6s infinite alternate;
  }
  .ka-loading-dot:nth-child(2) { animation-delay: .2s; }
  .ka-loading-dot:nth-child(3) { animation-delay: .4s; }

  @keyframes bounce {
    to { opacity: .2; transform: translateY(-4px); }
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 700px) {
    .ka-hero { padding: 44px 20px 48px; }
    .ka-grid { grid-template-columns: 1fr; }
    .ka-card { padding: 22px 18px; }
    .ka-new-rent-value { font-size: 22px; }
    .ka-rate-banner-inner { flex-wrap: wrap; gap: 8px; padding: 14px 16px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ka-result-card.visible { animation: none; }
    .ka-btn { transition: none; }
    .ka-rate-dot { animation: none; }
  }
</style>

<div class="ka-page">

  <div class="ka-hero">
    <div class="ka-hero-badge">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <circle cx="5" cy="5" r="4" fill="currentColor" opacity=".7"/>
      </svg>
      Bilgilendirme Aracı
    </div>
    <h1>Kira Artış <span>Hesaplama</span></h1>
    <p>TÜFE 12 aylık ortalamasına göre yasal kira artış tutarını ve yeni kira bedelini hesaplayın.</p>
  </div>

  <div class="ka-rate-banner">
    <div class="ka-rate-banner-inner">
      <span class="ka-rate-dot"></span>
      <span class="ka-rate-text" id="currentRateText">Güncel oran yükleniyor…</span>
      <span class="ka-rate-date" id="currentRateDate"></span>
    </div>
  </div>

  <div class="ka-container">
    <div class="ka-grid">

      <!-- Input card -->
      <div class="ka-card">
        <div class="ka-card-title">Bilgileri Girin</div>

        <div class="ka-field">
          <label class="ka-label" for="currentRent">Mevcut Aylık Kira</label>
          <div class="ka-input-wrap">
            <span class="ka-input-prefix">₺</span>
            <input
              class="ka-input"
              id="currentRent"
              type="text"
              inputmode="numeric"
              placeholder="15.000"
              autocomplete="off"
            />
          </div>
        </div>

        <div class="ka-field">
          <label class="ka-label" for="periodSelect">Sözleşme Yenilenme Ayı</label>
          <select class="ka-select" id="periodSelect">
            <option value="">Yükleniyor…</option>
          </select>
          <div class="ka-selected-rate" id="selectedRateBox" style="display:none">
            <span class="ka-selected-rate-label">TÜFE 12 aylık ortalama:</span>
            <span class="ka-selected-rate-value" id="selectedRateValue">—</span>
          </div>
        </div>

        <div class="ka-field">
          <label class="ka-label" for="customRate">Özel Oran Gir <span style="font-weight:400;color:var(--text-3)">(opsiyonel, TÜFE yerine)</span></label>
          <div class="ka-input-wrap">
            <span class="ka-input-prefix">%</span>
            <input
              class="ka-input"
              id="customRate"
              type="text"
              inputmode="decimal"
              placeholder="Boş bırakırsanız TÜFE uygulanır"
              autocomplete="off"
              style="padding-left:32px"
            />
          </div>
        </div>

        <div class="ka-error" id="kaError">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none">
            <circle cx="7.5" cy="7.5" r="6.5" stroke="#b91c1c" stroke-width="1.5"/>
            <path d="M7.5 4v4M7.5 10.5v.5" stroke="#b91c1c" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span id="kaErrorMsg">Lütfen geçerli bir kira bedeli girin.</span>
        </div>

        <button class="ka-btn" id="calcBtn" type="button">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M2 8h12M8 2v12" stroke="white" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          Hesapla
        </button>
      </div>

      <!-- Result card -->
      <div class="ka-card" id="resultCol">

        <div class="ka-loading" id="kaLoading">
          <span class="ka-loading-dot"></span>
          <span class="ka-loading-dot"></span>
          <span class="ka-loading-dot"></span>
        </div>

        <div class="ka-empty-state" id="kaEmpty">
          <div class="ka-empty-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M3 8L11 3L19 8V18C19 18.6 18.6 19 18 19H4C3.4 19 3 18.6 3 18V8Z" stroke="#7a90a8" stroke-width="1.5" fill="none"/>
              <path d="M9 19V12H13V19" stroke="#7a90a8" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <p>Kira bedelini ve dönemi seçip Hesapla'ya tıklayın.</p>
        </div>

        <div class="ka-result-card" id="kaResult">
          <div class="ka-card-title">Hesaplama Sonucu</div>

          <div class="ka-new-rent">
            <div class="ka-new-rent-label">Yeni Kira Bedeli</div>
            <div class="ka-new-rent-value" id="newRent">—</div>
          </div>

          <div class="ka-result-rows">
            <div class="ka-result-row">
              <span class="ka-result-label">Mevcut Kira</span>
              <span class="ka-result-value" id="oldRent">—</span>
            </div>
            <div class="ka-result-row">
              <span class="ka-result-label">Uygulanan Oran</span>
              <span class="ka-result-value" id="appliedRate">—</span>
            </div>
            <div class="ka-result-row">
              <span class="ka-result-label">Artış Tutarı</span>
              <span class="ka-result-value">
                <span class="ka-increase-badge" id="increaseAmount">—</span>
              </span>
            </div>
            <div class="ka-result-row">
              <span class="ka-result-label">Yıllık Fark</span>
              <span class="ka-result-value" id="yearlyDiff">—</span>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Disclaimer -->
    <div class="ka-disclaimer">
      <div class="ka-disclaimer-head">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <circle cx="8" cy="8" r="6.5" stroke="#7a90a8" stroke-width="1.5"/>
          <path d="M8 7v5M8 5v.5" stroke="#7a90a8" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span>Bilgilendirme Notu</span>
      </div>
      <p>Bu hesaplama bilgilendirme amaçlıdır. Kira artış oranı, Türk Borçlar Kanunu'nun 344. maddesi gereği TÜİK tarafından açıklanan TÜFE 12 aylık ortalamasını geçemez. Sözleşmede daha düşük bir oran belirlenmiş olabilir. Kesin bilgi için kira sözleşmenizi ve güncel TÜİK verilerini kontrol edin.</p>
    </div>
  </div>
</div>

{{> "seo-tool-content" tool="kira" appName="Kira Artış Hesaplama" appDescription="TÜFE on iki aylık ortalamasına göre yasal kira artış tutarını ve yeni kira bedelini hesaplama aracı."}}
<script>
(function () {
  'use strict';

  /* ── Config ────────────────────────────────── */
  var JSON_PATH = '/content/data/tufe-oranlari.json';

  /* ── Elements ──────────────────────────────── */
  var rentInput     = document.getElementById('currentRent');
  var periodSelect  = document.getElementById('periodSelect');
  var customRate    = document.getElementById('customRate');
  var calcBtn       = document.getElementById('calcBtn');
  var kaError       = document.getElementById('kaError');
  var kaErrorMsg    = document.getElementById('kaErrorMsg');
  var kaEmpty       = document.getElementById('kaEmpty');
  var kaResult      = document.getElementById('kaResult');
  var rateText      = document.getElementById('currentRateText');
  var rateDate      = document.getElementById('currentRateDate');
  var selectedBox   = document.getElementById('selectedRateBox');
  var selectedVal   = document.getElementById('selectedRateValue');

  var newRentEl     = document.getElementById('newRent');
  var oldRentEl     = document.getElementById('oldRent');
  var appliedRateEl = document.getElementById('appliedRate');
  var increaseEl    = document.getElementById('increaseAmount');
  var yearlyEl      = document.getElementById('yearlyDiff');

  var tufeData = null;

  /* ── Helpers ───────────────────────────────── */
  function formatMoney(n) {
    return new Intl.NumberFormat('tr-TR', {
      style: 'currency', currency: 'TRY',
      maximumFractionDigits: 2, minimumFractionDigits: 2
    }).format(n);
  }

  function parseMoney(v) {
    if (!v) return 0;
    return parseFloat(v.replace(/\./g, '').replace(',', '.').replace(/[^\d.]/g, '')) || 0;
  }

  function formatInput(input) {
    var raw = input.value.replace(/\./g, '').replace(/[^\d]/g, '');
    if (!raw) { input.value = ''; return; }
    input.value = new Intl.NumberFormat('tr-TR').format(parseInt(raw, 10));
  }

  /* ── Load JSON ─────────────────────────────── */
  function loadTufe() {
    fetch(JSON_PATH)
      .then(function (r) { return r.json(); })
      .then(function (data) {
        tufeData = data;
        populateSelect(data.oranlar);
        showCurrentRate(data);
      })
      .catch(function () {
        periodSelect.innerHTML = '<option value="">TÜFE verileri yüklenemedi</option>';
        rateText.textContent = 'TÜFE verileri yüklenemedi';
      });
  }

  function populateSelect(oranlar) {
    var html = '';
    for (var i = oranlar.length - 1; i >= 0; i--) {
      var o = oranlar[i];
      html += '<option value="' + o.oran + '" data-label="' + o.etiket + '">'
            + o.etiket + ' — %' + o.oran.toFixed(2)
            + '</option>';
    }
    periodSelect.innerHTML = html;
    updateSelectedRate();
  }

  function showCurrentRate(data) {
    var latest = data.oranlar[data.oranlar.length - 1];
    rateText.innerHTML = 'Güncel TÜFE 12 aylık ortalama: <strong>%' + latest.oran.toFixed(2) + '</strong>';
    rateDate.textContent = 'Son güncelleme: ' + data.guncelleme;
  }

  function updateSelectedRate() {
    var val = periodSelect.value;
    if (val) {
      selectedBox.style.display = 'flex';
      selectedVal.textContent = '%' + parseFloat(val).toFixed(2);
    } else {
      selectedBox.style.display = 'none';
    }
  }

  periodSelect.addEventListener('change', updateSelectedRate);

  /* ── Input formatting ──────────────────────── */
  rentInput.addEventListener('input', function () { formatInput(this); });

  rentInput.addEventListener('keydown', function (e) {
    if (e.key === 'Enter') calculate();
  });

  /* ── Calculate ─────────────────────────────── */
  function calculate() {
    var rent = parseMoney(rentInput.value);
    var customVal = customRate.value.replace(',', '.').replace(/[^\d.]/g, '');
    var rate;

    if (rent <= 0) {
      showError('Lütfen geçerli bir kira bedeli girin.');
      return;
    }

    if (customVal && parseFloat(customVal) > 0) {
      rate = parseFloat(customVal);
    } else {
      rate = parseFloat(periodSelect.value);
    }

    if (!rate || rate <= 0) {
      showError('Lütfen bir dönem seçin veya özel oran girin.');
      return;
    }

    hideError();

    var increase = rent * (rate / 100);
    var newRent = rent + increase;
    var yearlyDiff = increase * 12;

    newRentEl.textContent    = formatMoney(newRent);
    oldRentEl.textContent    = formatMoney(rent);
    appliedRateEl.textContent = '%' + rate.toFixed(2);
    increaseEl.textContent   = '+' + formatMoney(increase);
    yearlyEl.textContent     = formatMoney(yearlyDiff);

    kaEmpty.style.display = 'none';
    kaResult.classList.add('visible');
  }

  function showError(msg) {
    kaErrorMsg.textContent = msg;
    kaError.classList.add('visible');
    rentInput.style.borderColor = '#fca5a5';
  }

  function hideError() {
    kaError.classList.remove('visible');
    rentInput.style.borderColor = '';
  }

  calcBtn.addEventListener('click', calculate);

  /* ── Init ───────────────────────────────────── */
  loadTufe();
})();
</script>
