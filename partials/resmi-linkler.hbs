<style>
  /* ── Resmi Linkler Bottom Bar ────────────────── */
  .rl-bar {
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    z-index: 9990;
    background: linear-gradient(135deg, #142840 0%, #1E3A5F 100%);
    border-top: 1px solid rgba(200,162,74,.15);
    padding: 0;
    box-shadow: 0 -4px 20px rgba(15,28,46,.18);
  }

  .rl-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0;
  }

  .rl-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex: 1;
    padding: 10px 6px 9px;
    text-decoration: none;
    color: rgba(255,255,255,.65);
    transition: color .15s ease, background .15s ease;
    position: relative;
    min-width: 0;
  }

  .rl-link:hover {
    color: #ffffff;
    background: rgba(200,162,74,.10);
  }

  .rl-link:hover .rl-icon {
    color: #C8A24A;
  }

  /* Divider between items */
  .rl-link + .rl-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    bottom: 14px;
    width: 1px;
    background: rgba(255,255,255,.08);
  }

  .rl-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    transition: color .15s ease;
    color: rgba(255,255,255,.5);
  }

  .rl-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  .rl-text {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .03em;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    text-align: center;
  }

  /* ── Badge: "Resmî" indicator ────────────────── */
  .rl-badge {
    display: none;
    position: absolute;
    top: 5px;
    right: calc(50% - 24px);
    font-size: 7px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #C8A24A;
    background: rgba(200,162,74,.15);
    border-radius: 3px;
    padding: 1px 3px;
    line-height: 1;
  }

  /* ── Adjust FAB position to not overlap ──────── */
  .fab-wrap {
    bottom: 72px !important;
  }

  /* ── Mobile ──────────────────────────────────── */
  @media (max-width: 600px) {
    .rl-text {
      font-size: 9px;
      letter-spacing: 0;
    }

    .rl-link {
      padding: 8px 4px 7px;
    }

    .rl-icon svg {
      width: 16px;
      height: 16px;
    }

    .fab-wrap {
      bottom: 64px !important;
    }
  }

  @media (max-width: 380px) {
    .rl-text {
      display: none;
    }

    .rl-link {
      padding: 10px 4px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .rl-link { transition: none; }
  }
</style>

