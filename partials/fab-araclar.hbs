{{!-- ── Araçlar FAB ──────────────────────────────────────────── --}}
<style>
  /* ── FAB container ───────────────────────────── */
  .fab-wrap {
    position: fixed;
    right: 24px;
    bottom: 28px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }

  /* ── Menu panel ──────────────────────────────── */
  .fab-menu {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px) scale(.97);
    transition: opacity .22s ease, transform .22s ease;
  }

  .fab-menu.is-open {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  /* ── Menu items ──────────────────────────────── */
  .fab-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px 10px 12px;
    background: #ffffff;
    border: 1px solid rgba(30,58,95,.10);
    border-radius: 99px;
    box-shadow: 0 4px 18px rgba(15,28,46,.13);
    text-decoration: none;
    white-space: nowrap;
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
  }

  .fab-item:hover {
    transform: translateX(-3px);
    box-shadow: 0 6px 24px rgba(15,28,46,.18);
    background: #fafbfc;
  }

  .fab-item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(200,162,74,.13);
    flex-shrink: 0;
  }

  .fab-item-icon svg {
    width: 15px;
    height: 15px;
    fill: #C8A24A;
  }

  .fab-item-label {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .fab-item-main {
    font-size: 13.5px;
    font-weight: 700;
    color: #1E3A5F;
    line-height: 1.2;
  }

  .fab-item-sub {
    font-size: 11.5px;
    color: #7a90a8;
    font-weight: 400;
    line-height: 1.2;
  }

  /* ── Coming soon badge ───────────────────────── */
  .fab-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #C8A24A;
    background: rgba(200,162,74,.12);
    border-radius: 4px;
    padding: 1px 5px;
    margin-left: 4px;
    vertical-align: middle;
  }

  /* ── Main FAB button ─────────────────────────── */
  .fab-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 50px;
    padding: 0 20px 0 16px;
    background: linear-gradient(135deg, #1E3A5F 0%, #2a4f7c 100%);
    border: none;
    border-radius: 99px;
    box-shadow: 0 6px 24px rgba(30,58,95,.35);
    cursor: pointer;
    transition: transform .18s ease, box-shadow .18s ease;
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .01em;
  }

  .fab-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 32px rgba(30,58,95,.42);
  }

  .fab-btn:active {
    transform: translateY(0);
  }

  .fab-btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: rgba(200,162,74,.22);
    border-radius: 50%;
    flex-shrink: 0;
    transition: background .18s ease;
  }

  .fab-btn.is-open .fab-btn-icon {
    background: rgba(200,162,74,.35);
  }

  .fab-btn-icon svg {
    width: 14px;
    height: 14px;
    fill: #C8A24A;
    transition: transform .22s ease;
  }

  .fab-btn.is-open .fab-btn-icon svg {
    transform: rotate(45deg);
  }

  /* ── Mobile tweaks ───────────────────────────── */
  @media (max-width: 600px) {
    .fab-wrap {
      right: 16px;
      bottom: 20px;
    }

    .fab-btn {
      height: 46px;
      padding: 0 16px 0 12px;
      font-size: 13px;
    }

    .fab-item-sub {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fab-menu, .fab-btn, .fab-item, .fab-btn-icon svg {
      transition: none;
    }
  }
</style>

<div class="fab-wrap" id="fabWrap">

  <!-- Menu -->
  <div class="fab-menu" id="fabMenu" role="menu" aria-label="Araçlar menüsü">

    <!-- Tapu Harcı Hesaplama -->
