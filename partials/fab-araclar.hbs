        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 8L12 3L21 8V18C21 18.6 20.6 19 20 19H4C3.4 19 3 18.6 3 18V8ZM5 9.3V17H19V9.3L12 5.2L5 9.3ZM9 17V12H15V17"/>
        </svg>
      </span>
      <span class="fab-item-label">
        <span class="fab-item-main">Kira Artış Hesaplama</span>
        <span class="fab-item-sub">TÜFE oranıyla yasal zam hesapla</span>
      </span>
    </a>
<!-- Değer Artış Kazancı Hesaplama -->
    <a class="fab-item" href="/deger-artis-kazanci-hesaplama/" role="menuitem">
      <span class="fab-item-icon">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M16 6L18.29 8.29L13.41 13.17L9.41 9.17L2 16.59L3.41 18L9.41 12L13.41 16L19.71 9.71L22 12V6H16Z"/>
        </svg>
      </span>
      <span class="fab-item-label">
        <span class="fab-item-main">Değer Artış Kazancı</span>
        <span class="fab-item-sub">Gayrimenkul satış vergisi hesapla</span>
      </span>
    </a>
  </div>

  <!-- FAB button -->
  <button class="fab-btn" id="fabBtn" aria-haspopup="true" aria-expanded="false" aria-controls="fabMenu">
    <span class="fab-btn-icon">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M19 13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
      </svg>
    </span>
    Hesaplama Araçları
  </button> 
</div>

<script>
(function () {
  var btn  = document.getElementById('fabBtn');
  var menu = document.getElementById('fabMenu');
  var wrap = document.getElementById('fabWrap');
  if (!btn || !menu) return;

  function open() {
    menu.classList.add('is-open');
    btn.classList.add('is-open');
    btn.setAttribute('aria-expanded', 'true');
  }

  function close() {
    menu.classList.remove('is-open');
    btn.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
  }

  function toggle() {
    menu.classList.contains('is-open') ? close() : open();
  }

  btn.addEventListener('click', function (e) {
    e.stopPropagation();
    toggle();
  });

  // Dışarı tıklayınca kapat
  document.addEventListener('click', function (e) {
    if (!wrap.contains(e.target)) close();
  });

  // Escape tuşu
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') close();
  });

  // Modal-triggering items: override href and open modal instead
  document.querySelectorAll('.fab-item[data-open-modal]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      var modalId = this.getAttribute('data-open-modal');
      var modal = document.getElementById(modalId);
      if (modal) { e.preventDefault(); close(); modal.classList.add('is-open'); }
    });
  });
})();
</script>