{{#post}}

<style>
  .dak-page *, .dak-page *::before, .dak-page *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #1E3A5F; --navy-dark: #142840; --navy-light: #2a4f7c;
    --gold: #C8A24A; --gold-light: #debb6e;
    --surface: #ffffff; --surface-2: #f7f9fc; --surface-3: #eef2f7;
    --border: #dde3ec;
    --text-1: #0f1c2e; --text-2: #3d5068; --text-3: #7a90a8;
    --green: #16a34a; --green-bg: #f0fdf4; --green-bdr: #bbf7d0;
    --red: #dc2626; --red-bg: #fef2f2; --red-bdr: #fecaca;
    --radius-sm: 8px; --radius-md: 14px; --radius-lg: 22px;
    --shadow-md: 0 8px 28px rgba(15,28,46,.10);
    --transition: .18s ease;
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .dak-page { font-family: var(--font-sans); background: var(--surface-2); min-height: 100vh; color: var(--text-1); }

  /* ── Hero ───────────────────────────────────── */
  .dak-hero {
    background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 55%, var(--navy-light) 100%);
    padding: 56px 24px 52px; text-align: center; position: relative; overflow: hidden;
  }
  .dak-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 80% at 80% 20%, rgba(200,162,74,.13) 0%, transparent 70%),
                radial-gradient(ellipse 40% 60% at 20% 80%, rgba(200,162,74,.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .dak-hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(200,162,74,.18); border: 1px solid rgba(200,162,74,.35);
    border-radius: 99px; padding: 5px 14px; font-size: 12px; font-weight: 600;
    letter-spacing: .06em; text-transform: uppercase; color: var(--gold-light); margin-bottom: 20px;
  }
  .dak-hero h1 { font-size: clamp(24px, 5vw, 40px); font-weight: 800; color: #fff; line-height: 1.15; letter-spacing: -.02em; margin-bottom: 14px; }
  .dak-hero h1 span { color: var(--gold); }
  .dak-hero p { font-size: 16px; color: rgba(255,255,255,.72); max-width: 540px; margin: 0 auto; line-height: 1.6; }

  /* ── Info pills ─────────────────────────────── */
  .dak-pills { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 20px; max-width: 960px; margin-left: auto; margin-right: auto; padding: 0 20px; }
  .dak-pill {
    display: flex; align-items: center; gap: 6px; background: var(--surface);
    border: 1px solid var(--border); border-radius: 99px; padding: 7px 14px;
    font-size: 12.5px; font-weight: 600; color: var(--text-2); box-shadow: 0 2px 8px rgba(15,28,46,.07);
  }
  .dak-pill .pill-val { font-family: var(--font-mono); color: var(--navy); font-weight: 800; }

  /* ── Container ──────────────────────────────── */
  .dak-container { max-width: 960px; margin: 0 auto; padding: 0 20px 64px; }
  .dak-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px; }

  /* ── Card ────────────────────────────────────── */
  .dak-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 28px; box-shadow: var(--shadow-md); }
  .dak-card-title {
    font-size: 13px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
    color: var(--text-3); margin-bottom: 22px; display: flex; align-items: center; gap: 8px;
  }
  .dak-card-title::before { content: ''; width: 3px; height: 14px; background: var(--gold); border-radius: 2px; }

  /* ── Form ────────────────────────────────────── */
  .dak-field { margin-bottom: 16px; }
  .dak-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .dak-label { display: block; font-size: 13px; font-weight: 600; color: var(--text-2); margin-bottom: 6px; }
  .dak-label-hint { font-weight: 400; color: var(--text-3); }
  .dak-input-wrap { position: relative; }
  .dak-input-prefix {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 14px; font-weight: 700; color: var(--text-3); pointer-events: none; font-family: var(--font-mono);
  }
  .dak-input {
    width: 100%; height: 46px; border: 1.5px solid var(--border); border-radius: var(--radius-md);
    padding: 0 14px 0 36px; font-size: 15px; font-family: var(--font-mono); font-weight: 600;
    color: var(--text-1); background: var(--surface); outline: none; -webkit-appearance: none;
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .dak-input:focus { border-color: var(--navy); box-shadow: 0 0 0 3px rgba(30,58,95,.10); }
  .dak-input::placeholder { color: var(--text-3); font-weight: 400; font-family: var(--font-sans); }
  .dak-input.no-prefix { padding-left: 14px; }
  .dak-input-sm { height: 42px; font-size: 14px; }

  .dak-select {
    width: 100%; height: 46px; border: 1.5px solid var(--border); border-radius: var(--radius-md);
    padding: 0 14px; font-size: 14px; font-weight: 600; color: var(--text-1); background: var(--surface);
    outline: none; cursor: pointer; -webkit-appearance: none; appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1.5L6 6.5L11 1.5' stroke='%237a90a8' stroke-width='1.8' stroke-linecap='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat; background-position: right 14px center; background-size: 12px;
  }

  /* ── Section divider ────────────────────────── */
  .dak-divider { height: 1px; background: var(--surface-3); margin: 18px 0; }

  /* ── Button ─────────────────────────────────── */
  .dak-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 52px; margin-top: 20px; border: none; border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
    color: #fff; font-size: 15px; font-weight: 700; cursor: pointer;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: 0 4px 16px rgba(30,58,95,.28); letter-spacing: .02em;
  }
  .dak-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(30,58,95,.36); }
  .dak-btn:active { transform: translateY(0); }
  .dak-btn svg { flex-shrink: 0; }

  .dak-error { display: none; align-items: center; gap: 8px; background: var(--red-bg); border: 1px solid var(--red-bdr); border-radius: var(--radius-sm); padding: 10px 14px; font-size: 13px; font-weight: 500; color: var(--red); margin-top: 12px; }
  .dak-error.visible { display: flex; }

  /* ── Result ─────────────────────────────────── */
  .dak-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 40px 20px; text-align: center; color: var(--text-3); gap: 12px; min-height: 300px;
  }
  .dak-empty-icon { width: 52px; height: 52px; background: var(--surface-3); border-radius: 50%; display: flex; align-items: center; justify-content: center; }
  .dak-empty p { font-size: 14px; line-height: 1.5; max-width: 200px; }

  .dak-result { display: none; flex-direction: column; }
  .dak-result.visible { display: flex; animation: dakSlide .28s ease; }
  @keyframes dakSlide { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* ── Verdict banner ─────────────────────────── */
  .dak-verdict {
    border-radius: var(--radius-md); padding: 18px 20px; text-align: center; margin-bottom: 16px;
  }
  .dak-verdict.tax { background: linear-gradient(135deg, var(--navy-dark), var(--navy)); }
  .dak-verdict.no-tax { background: var(--green-bg); border: 1px solid var(--green-bdr); }
  .dak-verdict-label { font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; margin-bottom: 6px; }
  .dak-verdict.tax .dak-verdict-label { color: rgba(255,255,255,.6); }
  .dak-verdict.no-tax .dak-verdict-label { color: var(--green); }
  .dak-verdict-value { font-size: 26px; font-weight: 800; font-family: var(--font-mono); letter-spacing: -.02em; }
  .dak-verdict.tax .dak-verdict-value { color: var(--gold); }
  .dak-verdict.no-tax .dak-verdict-value { color: var(--green); font-size: 18px; font-family: var(--font-sans); }

  /* ── Detail rows ────────────────────────────── */
  .dak-rows { display: flex; flex-direction: column; }
  .dak-row-item { display: flex; justify-content: space-between; align-items: center; padding: 11px 0; border-bottom: 1px solid var(--surface-3); }
  .dak-row-item:last-child { border-bottom: none; }
  .dak-row-label { font-size: 13px; color: var(--text-2); font-weight: 500; }
  .dak-row-value { font-size: 13.5px; font-weight: 700; color: var(--text-1); font-family: var(--font-mono); }
  .dak-row-item.highlight .dak-row-value { color: var(--navy); font-size: 14px; }

  /* ── Tax breakdown ──────────────────────────── */
  .dak-breakdown { margin-top: 12px; }
  .dak-breakdown-title { font-size: 12px; font-weight: 700; color: var(--text-3); letter-spacing: .06em; text-transform: uppercase; margin-bottom: 8px; }
  .dak-bracket { display: flex; justify-content: space-between; padding: 6px 0; font-size: 12px; color: var(--text-3); }
  .dak-bracket-rate { font-weight: 700; color: var(--text-2); min-width: 30px; }
  .dak-bracket-amount { font-family: var(--font-mono); font-weight: 600; color: var(--text-1); }

  /* ── Disclaimer ─────────────────────────────── */
  .dak-disclaimer { margin-top: 20px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px 24px; box-shadow: 0 2px 8px rgba(15,28,46,.07); }
  .dak-disclaimer-head { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .dak-disclaimer-head span { font-size: 13px; font-weight: 700; color: var(--text-2); }
  .dak-disclaimer p { font-size: 13px; color: var(--text-3); line-height: 1.7; }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 700px) {
    .dak-hero { padding: 44px 20px 48px; }
    .dak-grid { grid-template-columns: 1fr; }
    .dak-card { padding: 22px 18px; }
    .dak-row { grid-template-columns: 1fr 1fr; gap: 8px; }
    .dak-verdict-value { font-size: 20px; }
    .dak-pills { gap: 8px; }
  }
  @media (prefers-reduced-motion: reduce) { .dak-result.visible { animation: none; } .dak-btn { transition: none; } }
</style>

<div class="dak-page">

  <div class="dak-hero">
    <div class="dak-hero-badge">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" fill="currentColor" opacity=".7"/></svg>
      Bilgilendirme Aracı
    </div>
    <h1>Değer Artış <span>Kazancı</span></h1>
    <p>Gayrimenkul satışında 5 yıl kuralı, Yİ-ÜFE endekslemesi ve gelir vergisini hesaplayın.</p>
  </div>

  <div class="dak-pills">
    <div class="dak-pill"><span class="pill-val">5 yıl</span> kuralı</div>
    <div class="dak-pill">İstisna <span class="pill-val">150.000 ₺</span></div>
    <div class="dak-pill">Yİ-ÜFE <span class="pill-val">%10+</span> endeksleme</div>
  </div>

  <div class="dak-container">
    <div class="dak-grid">

      <!-- Input -->
      <div class="dak-card">
        <div class="dak-card-title">Bilgileri Girin</div>

        <div class="dak-row">
          <div class="dak-field">
            <label class="dak-label">Alış Tarihi</label>
            <input class="dak-input dak-input-sm no-prefix" id="dakBuyDate" type="month" />
          </div>
          <div class="dak-field">
            <label class="dak-label">Satış Tarihi</label>
            <input class="dak-input dak-input-sm no-prefix" id="dakSellDate" type="month" />
          </div>
        </div>

        <div class="dak-field">
          <label class="dak-label">Alış Bedeli</label>
          <div class="dak-input-wrap">
            <span class="dak-input-prefix">₺</span>
            <input class="dak-input" id="dakBuyPrice" type="text" inputmode="numeric" placeholder="1.500.000" autocomplete="off" />
          </div>
        </div>

        <div class="dak-field">
          <label class="dak-label">Satış Bedeli</label>
          <div class="dak-input-wrap">
            <span class="dak-input-prefix">₺</span>
            <input class="dak-input" id="dakSellPrice" type="text" inputmode="numeric" placeholder="3.000.000" autocomplete="off" />
          </div>
        </div>

        <div class="dak-divider"></div>

        <div class="dak-row">
          <div class="dak-field">
            <label class="dak-label">Yİ-ÜFE <span class="dak-label-hint">(alış ayından önceki ay)</span></label>
            <input class="dak-input no-prefix dak-input-sm" id="dakUfeBuy" type="text" inputmode="decimal" placeholder="1856.20" autocomplete="off" />
          </div>
          <div class="dak-field">
            <label class="dak-label">Yİ-ÜFE <span class="dak-label-hint">(satış ayından önceki ay)</span></label>
            <input class="dak-input no-prefix dak-input-sm" id="dakUfeSell" type="text" inputmode="decimal" placeholder="2894.50" autocomplete="off" />
          </div>
        </div>

        <div class="dak-field">
          <label class="dak-label">Giderler <span class="dak-label-hint">(tapu harcı, komisyon vb. — opsiyonel)</span></label>
          <div class="dak-input-wrap">
            <span class="dak-input-prefix">₺</span>
            <input class="dak-input" id="dakExpenses" type="text" inputmode="numeric" placeholder="60.000" autocomplete="off" />
          </div>
        </div>

        <div class="dak-error" id="dakError">
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><circle cx="7.5" cy="7.5" r="6.5" stroke="#dc2626" stroke-width="1.5"/><path d="M7.5 4v4M7.5 10.5v.5" stroke="#dc2626" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span id="dakErrorMsg"></span>
        </div>

        <button class="dak-btn" id="dakCalcBtn" type="button">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L14 8L8 14M2 8H14" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Hesapla
        </button>
      </div>

      <!-- Result -->
      <div class="dak-card" id="dakResultCol">

        <div class="dak-empty" id="dakEmpty">
          <div class="dak-empty-icon">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
              <path d="M16 6L18.29 8.29L13.41 13.17L9.41 9.17L2 16.59L3.41 18L9.41 12L13.41 16L19.71 9.71L22 12V6H16Z" fill="#7a90a8" opacity=".5" transform="scale(.85) translate(1,2)"/>
            </svg>
          </div>
          <p>Alış ve satış bilgilerini girip Hesapla'ya tıklayın.</p>
        </div>

        <div class="dak-result" id="dakResult">
          <div class="dak-card-title">Hesaplama Sonucu</div>

          <div class="dak-verdict" id="dakVerdict">
            <div class="dak-verdict-label" id="dakVerdictLabel"></div>
            <div class="dak-verdict-value" id="dakVerdictValue"></div>
          </div>

          <div class="dak-rows">
            <div class="dak-row-item"><span class="dak-row-label">Elde Tutma Süresi</span><span class="dak-row-value" id="rHoldPeriod"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">Yİ-ÜFE Artış Oranı</span><span class="dak-row-value" id="rUfeRate"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">Endekslenmiş Alış Bedeli</span><span class="dak-row-value" id="rAdjustedBuy"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">Gayrisafi Kazanç</span><span class="dak-row-value" id="rGrossGain"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">Giderler</span><span class="dak-row-value" id="rExpenses"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">Safi Kazanç</span><span class="dak-row-value" id="rNetGain"></span></div>
            <div class="dak-row-item"><span class="dak-row-label">İstisna Tutarı (2026)</span><span class="dak-row-value" id="rExemption"></span></div>
            <div class="dak-row-item highlight"><span class="dak-row-label">Vergiye Tabi Tutar</span><span class="dak-row-value" id="rTaxable"></span></div>
          </div>

          <div class="dak-breakdown" id="dakBreakdown" style="display:none">
            <div class="dak-breakdown-title">Gelir Vergisi Dilimleri</div>
            <div id="dakBrackets"></div>
          </div>
        </div>

      </div>
    </div>

    <div class="dak-disclaimer">
      <div class="dak-disclaimer-head">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="#7a90a8" stroke-width="1.5"/><path d="M8 7v5M8 5v.5" stroke="#7a90a8" stroke-width="1.5" stroke-linecap="round"/></svg>
        <span>Bilgilendirme Notu</span>
      </div>
      <p>Bu hesaplama bilgilendirme amaçlıdır. Değer artış kazancı vergisi, Gelir Vergisi Kanunu'nun Mükerrer 80. maddesi kapsamında düzenlenmektedir. Yİ-ÜFE endeks değerlerini TÜİK'in güncel verilerinden kontrol edin. İvazsız edinimler (miras, bağış) bu hesaplamaya dahil değildir. Kesin sonuç için mali müşavirinize veya Gelir İdaresi Başkanlığı'na başvurun.</p>
    </div>
  </div>
</div>

{{> "seo-tool-content" tool="deger-artis" appName="Değer Artış Kazancı Hesaplama" appDescription="Gayrimenkul satışında endekslenmiş maliyet, istisna ve tahmini değer artış kazancı vergisi hesaplama aracı."}}
<script>
(function () {
  'use strict';

  /* ── 2026 Gelir Vergisi Tarifesi (ücret dışı) ── */
  var TAX_BRACKETS = [
    { limit: 190000,   rate: 0.15 },
    { limit: 400000,   rate: 0.20 },
    { limit: 1000000,  rate: 0.27 },
    { limit: 5300000,  rate: 0.35 },
    { limit: Infinity, rate: 0.40 }
  ];
  var EXEMPTION = 150000;
  var UFE_THRESHOLD = 0.10;

  /* ── Elements ──────────────────────────────── */
  var buyDateEl   = document.getElementById('dakBuyDate');
  var sellDateEl  = document.getElementById('dakSellDate');
  var buyPriceEl  = document.getElementById('dakBuyPrice');
  var sellPriceEl = document.getElementById('dakSellPrice');
  var ufeBuyEl    = document.getElementById('dakUfeBuy');
  var ufeSellEl   = document.getElementById('dakUfeSell');
  var expensesEl  = document.getElementById('dakExpenses');
  var calcBtn     = document.getElementById('dakCalcBtn');
  var errorEl     = document.getElementById('dakError');
  var errorMsg    = document.getElementById('dakErrorMsg');
  var emptyEl     = document.getElementById('dakEmpty');
  var resultEl    = document.getElementById('dakResult');

  /* ── Helpers ───────────────────────────────── */
  function fmt(n) {
    return new Intl.NumberFormat('tr-TR', { style:'currency', currency:'TRY', maximumFractionDigits:2, minimumFractionDigits:2 }).format(n);
  }

  function parseMoney(v) {
    if (!v) return 0;
    return parseFloat(v.replace(/\./g,'').replace(',','.').replace(/[^\d.]/g,'')) || 0;
  }

  function parseDecimal(v) {
    if (!v) return 0;
    return parseFloat(v.replace(',','.').replace(/[^\d.]/g,'')) || 0;
  }

  function formatInput(el) {
    var raw = el.value.replace(/\./g,'').replace(/[^\d]/g,'');
    if (!raw) { el.value = ''; return; }
    el.value = new Intl.NumberFormat('tr-TR').format(parseInt(raw, 10));
  }

  [buyPriceEl, sellPriceEl, expensesEl].forEach(function(el) {
    el.addEventListener('input', function() { formatInput(this); });
  });

  function showError(msg) { errorMsg.textContent = msg; errorEl.classList.add('visible'); }
  function hideError() { errorEl.classList.remove('visible'); }

  /* ── Tax calculation ───────────────────────── */
  function calculateTax(taxable) {
    var totalTax = 0;
    var remaining = taxable;
    var prev = 0;
    var breakdown = [];

    for (var i = 0; i < TAX_BRACKETS.length; i++) {
      var b = TAX_BRACKETS[i];
      var bracketSize = b.limit - prev;
      var inBracket = Math.min(remaining, bracketSize);
      if (inBracket <= 0) break;
      var tax = inBracket * b.rate;
      totalTax += tax;
      breakdown.push({
        range: fmt(prev) + ' – ' + (b.limit === Infinity ? '...' : fmt(b.limit)),
        rate: (b.rate * 100).toFixed(0) + '%',
        amount: fmt(tax)
      });
      remaining -= inBracket;
      prev = b.limit;
    }
    return { total: totalTax, breakdown: breakdown };
  }

  /* ── Main calc ─────────────────────────────── */
  function calculate() {
    hideError();

    var buyDate   = buyDateEl.value;
    var sellDate  = sellDateEl.value;
    var buyPrice  = parseMoney(buyPriceEl.value);
    var sellPrice = parseMoney(sellPriceEl.value);
    var ufeBuy    = parseDecimal(ufeBuyEl.value);
    var ufeSell   = parseDecimal(ufeSellEl.value);
    var expenses  = parseMoney(expensesEl.value);

    if (!buyDate || !sellDate) { showError('Lütfen alış ve satış tarihlerini seçin.'); return; }
    if (buyPrice <= 0) { showError('Lütfen geçerli bir alış bedeli girin.'); return; }
    if (sellPrice <= 0) { showError('Lütfen geçerli bir satış bedeli girin.'); return; }
    if (ufeBuy <= 0 || ufeSell <= 0) { showError('Lütfen Yİ-ÜFE endeks değerlerini girin.'); return; }

    /* 5 year check */
    var bd = new Date(buyDate + '-01');
    var sd = new Date(sellDate + '-01');
    var diffMs = sd - bd;
    var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    var years = Math.floor(diffDays / 365);
    var months = Math.floor((diffDays % 365) / 30);

    var holdText = years + ' yıl ' + months + ' ay';
    document.getElementById('rHoldPeriod').textContent = holdText;

    /* 5 year → no tax */
    if (diffDays >= 5 * 365) {
      emptyEl.style.display = 'none';
      resultEl.classList.add('visible');

      var verdict = document.getElementById('dakVerdict');
      verdict.className = 'dak-verdict no-tax';
      document.getElementById('dakVerdictLabel').textContent = 'Sonuç';
      document.getElementById('dakVerdictValue').textContent = '5 yıl dolmuş — Vergi yok';

      document.getElementById('rUfeRate').textContent = '—';
      document.getElementById('rAdjustedBuy').textContent = '—';
      document.getElementById('rGrossGain').textContent = '—';
      document.getElementById('rExpenses').textContent = '—';
      document.getElementById('rNetGain').textContent = '—';
      document.getElementById('rExemption').textContent = '—';
      document.getElementById('rTaxable').textContent = '—';
      document.getElementById('dakBreakdown').style.display = 'none';
      return;
    }

    /* Yİ-ÜFE endeksleme */
    var ufeRate = (ufeSell - ufeBuy) / ufeBuy;
    var ufePercent = (ufeRate * 100).toFixed(2);
    document.getElementById('rUfeRate').textContent = '%' + ufePercent;

    var adjustedBuy = buyPrice;
    if (ufeRate >= UFE_THRESHOLD) {
      adjustedBuy = buyPrice * (1 + ufeRate);
    }
    document.getElementById('rAdjustedBuy').textContent = fmt(adjustedBuy);

    /* Kazanç */
    var grossGain = sellPrice - adjustedBuy;
    document.getElementById('rGrossGain').textContent = fmt(grossGain);
    document.getElementById('rExpenses').textContent = fmt(expenses);

    var netGain = grossGain - expenses;
    if (netGain < 0) netGain = 0;
    document.getElementById('rNetGain').textContent = fmt(netGain);

    document.getElementById('rExemption').textContent = fmt(EXEMPTION);

    var taxable = netGain - EXEMPTION;
    if (taxable < 0) taxable = 0;
    document.getElementById('rTaxable').textContent = fmt(taxable);

    emptyEl.style.display = 'none';
    resultEl.classList.add('visible');

    var verdict = document.getElementById('dakVerdict');
    var breakdownDiv = document.getElementById('dakBreakdown');

    if (taxable <= 0) {
      verdict.className = 'dak-verdict no-tax';
      document.getElementById('dakVerdictLabel').textContent = 'Sonuç';
      document.getElementById('dakVerdictValue').textContent = 'İstisna kapsamında — Vergi yok';
      breakdownDiv.style.display = 'none';
    } else {
      var result = calculateTax(taxable);
      verdict.className = 'dak-verdict tax';
      document.getElementById('dakVerdictLabel').textContent = 'Ödenecek Gelir Vergisi';
      document.getElementById('dakVerdictValue').textContent = fmt(result.total);

      var bracketsHtml = '';
      for (var i = 0; i < result.breakdown.length; i++) {
        var b = result.breakdown[i];
        bracketsHtml += '<div class="dak-bracket">'
          + '<span class="dak-bracket-rate">' + b.rate + '</span>'
          + '<span>' + b.range + '</span>'
          + '<span class="dak-bracket-amount">' + b.amount + '</span>'
          + '</div>';
      }
      document.getElementById('dakBrackets').innerHTML = bracketsHtml;
      breakdownDiv.style.display = 'block';
    }
  }

  calcBtn.addEventListener('click', calculate);

  /* Enter key */
  document.querySelectorAll('.dak-input').forEach(function(el) {
    el.addEventListener('keydown', function(e) { if (e.key === 'Enter') calculate(); });
  });

})();
</script>
{{/post}}
