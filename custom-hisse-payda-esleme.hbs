<div class="fab-items" id="fabItems">
<a class="fab-item" href="/tapu-harci-hesaplama/"><span class="fab-lbl">Tapu Harcı Hesaplama</span><span class="fab-dot"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2h8v12l-2-1.5L8 14l-2-1.5L4 14V2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M6 6h4M6 8.5h2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span></a>
