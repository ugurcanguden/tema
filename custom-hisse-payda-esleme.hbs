{{!< default}}
<style>
.hp-page *,.hp-page *::before,.hp-page *::after{box-sizing:border-box;margin:0;padding:0}
:root{--navy:#1E3A5F;--navy-dark:#142840;--navy-light:#2a4f7c;--gold:#C8A24A;--gold-light:#debb6e;--surface:#fff;--surface-2:#f7f9fc;--surface-3:#eef2f7;--border:#dde3ec;--text-1:#0f1c2e;--text-2:#3d5068;--text-3:#7a90a8;--radius-sm:8px;--radius-md:14px;--radius-lg:22px;--shadow-md:0 8px 28px rgba(15,28,46,.10);--transition:.18s ease;--font-sans:'Inter',system-ui,-apple-system,sans-serif;--font-mono:'JetBrains Mono','Fira Code',monospace}
.hp-page{font-family:var(--font-sans);background:var(--surface-2);min-height:100vh;color:var(--text-1)}
.hp-hero{background:linear-gradient(135deg,var(--navy-dark),var(--navy) 55%,var(--navy-light));padding:56px 24px 52px;text-align:center;position:relative;overflow:hidden}
.hp-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 20%,rgba(200,162,74,.13),transparent 70%),radial-gradient(ellipse 40% 60% at 20% 80%,rgba(200,162,74,.08),transparent 60%);pointer-events:none}
.hp-hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(200,162,74,.18);border:1px solid rgba(200,162,74,.35);border-radius:99px;padding:5px 14px;font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--gold-light);margin-bottom:20px}
.hp-hero h1{font-size:clamp(26px,5vw,42px);font-weight:800;color:#fff;line-height:1.15;letter-spacing:-.02em;margin-bottom:14px}.hp-hero h1 span{color:var(--gold)}
.hp-hero p{font-size:16px;color:rgba(255,255,255,.72);max-width:540px;margin:0 auto;line-height:1.6}
.hp-container{max-width:960px;margin:0 auto;padding:0 20px 64px}
.hp-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px}
.hp-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:28px;box-shadow:var(--shadow-md)}
.hp-card-title{font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-3);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.hp-card-title::before{content:'';width:3px;height:14px;background:var(--gold);border-radius:2px}
.hp-qi{margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--surface-3)}
.hp-qi-lbl{display:block;font-size:13px;font-weight:600;color:var(--text-2);margin-bottom:7px}
.hp-qi-lbl span{font-weight:400;color:var(--text-3)}
.hp-qi-row{display:flex;gap:8px}
.hp-qi-input{flex:1;height:44px;border:1.5px solid var(--border);border-radius:var(--radius-md);padding:0 14px;font-size:14px;font-family:var(--font-mono);font-weight:600;color:var(--text-1);background:var(--surface);outline:none;transition:border-color var(--transition),box-shadow var(--transition)}
.hp-qi-input:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,58,95,.10)}
.hp-qi-input::placeholder{color:var(--text-3);font-weight:400;font-family:var(--font-sans)}
.hp-qi-btn{height:44px;padding:0 14px;border:1.5px solid var(--navy);border-radius:var(--radius-md);background:var(--navy);color:#fff;font-size:13px;font-weight:700;cursor:pointer;flex-shrink:0;transition:background var(--transition)}
.hp-qi-btn:hover{background:var(--navy-light)}
.hp-rows{margin-bottom:4px}
.hp-row{display:flex;align-items:flex-end;gap:8px;padding:8px 0;border-bottom:1px solid var(--surface-3)}
.hp-row:last-child{border-bottom:none}
.hp-row-num{width:18px;flex-shrink:0;font-size:12px;font-weight:700;color:var(--text-3);text-align:right;padding-bottom:13px}
.hp-frac{display:flex;align-items:flex-end;gap:6px;flex:1}
.hp-frac-f{flex:1;display:flex;flex-direction:column;gap:5px;min-width:0}
.hp-frac-lbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3)}
.hp-frac-inp{width:100%;height:44px;border:1.5px solid var(--border);border-radius:var(--radius-md);padding:0 10px;font-size:16px;font-family:var(--font-mono);font-weight:700;color:var(--text-1);background:var(--surface);outline:none;-webkit-appearance:none;text-align:center;transition:border-color var(--transition),box-shadow var(--transition)}
.hp-frac-inp:focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(30,58,95,.10)}
.hp-frac-inp::placeholder{color:var(--text-3);font-weight:400;font-family:var(--font-sans);font-size:13px;text-align:left}
.hp-frac-sep{font-size:22px;font-weight:800;color:var(--text-3);padding-bottom:8px;flex-shrink:0;user-select:none;line-height:1}
.hp-del{height:44px;width:36px;border:1.5px solid var(--border);border-radius:var(--radius-sm);background:var(--surface);color:var(--text-3);font-size:18px;cursor:pointer;transition:all var(--transition);flex-shrink:0;display:flex;align-items:center;justify-content:center;line-height:1}
.hp-del:hover{border-color:#fca5a5;color:#b91c1c;background:#fff5f5}
.hp-add{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;height:40px;margin-top:8px;border:1.5px dashed var(--border);border-radius:var(--radius-md);background:transparent;color:var(--text-2);font-size:13px;font-weight:600;cursor:pointer;transition:all var(--transition)}
.hp-add:hover{border-color:var(--navy-light);color:var(--navy);background:rgba(30,58,95,.03)}
.hp-err{display:none;align-items:center;gap:8px;background:#fff5f5;border:1px solid #fecaca;border-radius:var(--radius-sm);padding:10px 14px;font-size:13px;font-weight:500;color:#b91c1c;margin-top:10px}
.hp-err.on{display:flex}
.hp-warn{display:none;align-items:flex-start;gap:8px;background:rgba(254,243,199,.6);border:1px solid rgba(252,211,77,.4);border-radius:var(--radius-sm);padding:10px 14px;font-size:12px;font-weight:500;color:#92400e;margin-top:8px;line-height:1.5}
.hp-warn.on{display:flex}
.hp-info{display:flex;align-items:flex-start;gap:8px;padding:10px 12px;background:rgba(200,162,74,.06);border:1px solid rgba(200,162,74,.18);border-radius:var(--radius-sm);font-size:12px;color:var(--text-2);line-height:1.5;margin-top:12px}
.hp-info svg{flex-shrink:0;margin-top:1px}
.hp-btns{display:flex;gap:8px;margin-top:16px}
.hp-calc{flex:1;height:50px;border:none;border-radius:var(--radius-md);background:linear-gradient(135deg,var(--navy),var(--navy-light));color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:transform var(--transition),box-shadow var(--transition);box-shadow:0 4px 16px rgba(30,58,95,.28);letter-spacing:.02em;display:flex;align-items:center;justify-content:center;gap:8px}
.hp-calc:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(30,58,95,.36)}.hp-calc:active{transform:translateY(0)}
.hp-clear{height:50px;padding:0 18px;border:1.5px solid var(--border);border-radius:var(--radius-md);background:var(--surface);color:var(--text-2);font-size:14px;font-weight:600;cursor:pointer;flex-shrink:0;transition:all var(--transition)}
.hp-clear:hover{border-color:var(--navy-light);color:var(--navy)}
.hp-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;text-align:center;color:var(--text-3);gap:12px;min-height:260px}
.hp-empty-icon{width:52px;height:52px;background:var(--surface-3);border-radius:50%;display:flex;align-items:center;justify-content:center}
.hp-empty p{font-size:14px;line-height:1.5;max-width:200px}
.hp-res{display:none;flex-direction:column}.hp-res.on{display:flex;animation:hpIn .28s ease}
@keyframes hpIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.hp-payda-box{background:linear-gradient(135deg,var(--navy-dark),var(--navy));border-radius:var(--radius-md);padding:14px 18px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.hp-payda-lbl{font-size:13px;font-weight:600;color:rgba(255,255,255,.75)}
.hp-payda-val{font-size:28px;font-weight:800;color:var(--gold);font-family:var(--font-mono);letter-spacing:-.02em}
.hp-tbl{width:100%;border-collapse:collapse;font-size:13px;margin-bottom:14px}
.hp-tbl th{text-align:left;padding:7px 8px;font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);border-bottom:2px solid var(--surface-3)}
.hp-tbl td{padding:9px 8px;border-bottom:1px solid var(--surface-3)}
.hp-tbl tr:last-child td{border-bottom:none}
.hp-td-n{color:var(--text-3);font-family:var(--font-sans);font-weight:600;font-size:12px}
.hp-td-orig{color:var(--text-2);font-family:var(--font-mono);font-weight:600}
.hp-td-mono{color:var(--text-2);font-family:var(--font-mono);font-weight:600}
.hp-td-x{color:var(--text-3);font-family:var(--font-mono);font-size:12px}
.hp-td-eq{color:var(--navy);font-family:var(--font-mono);font-weight:800;font-size:14px}
.hp-total{border-radius:var(--radius-md);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
.hp-total-ok{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.25)}
.hp-total-low{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.28)}
.hp-total-hi{background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25)}
.hp-total-sublbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);margin-bottom:4px}
.hp-total-frac{font-size:20px;font-weight:800;font-family:var(--font-mono);color:var(--text-1)}
.hp-total-msg{font-size:12.5px;font-weight:600;line-height:1.5;text-align:right;max-width:180px}
.hp-total-ok .hp-total-msg{color:#16a34a}
.hp-total-low .hp-total-msg{color:#d97706}
.hp-total-hi .hp-total-msg{color:#dc2626}
.hp-disc{margin-top:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 24px;box-shadow:0 2px 8px rgba(15,28,46,.07)}
.hp-disc-head{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.hp-disc-head span{font-size:13px;font-weight:700;color:var(--text-2)}
.hp-disc p{font-size:13px;color:var(--text-3);line-height:1.7}
@media(max-width:700px){.hp-hero{padding:44px 20px 48px}.hp-grid{grid-template-columns:1fr}.hp-card{padding:22px 18px}.hp-payda-val{font-size:22px}.hp-btns{flex-direction:column}.hp-clear{width:100%}.hp-col-pay,.hp-col-payda{display:none}}
@media(prefers-reduced-motion:reduce){.hp-res.on{animation:none}.hp-calc{transition:none}}
</style>

<div class="hp-page">
<div class="hp-hero">
<div class="hp-hero-badge"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" fill="currentColor" opacity=".7"/></svg> Hesaplama Aracı</div>
<h1>Kat İrtifakı / Kat Mülkiyeti;<br><span>Hisselerin paydalarını eşitleme aracı</span></h1>
<p>Kat irtifakı ve kat mülkiyeti işlemlerinde farklı paydalara sahip hisse oranlarını ortak paydaya dönüştürür.</p>
</div>

<div class="hp-container">
<div class="hp-grid">

<div class="hp-card">
<div class="hp-card-title">Hisseler</div>

<div class="hp-qi">
<label class="hp-qi-lbl">Hızlı Giriş <span>(opsiyonel — 1/5, 2/4, 3/10)</span></label>
<div class="hp-qi-row">
<input class="hp-qi-input" id="hpQiInput" type="text" placeholder="Örn: 1/5, 2/4, 3/10" autocomplete="off"/>
<button class="hp-qi-btn" id="hpQiBtn" type="button">Aktar</button>
</div>
</div>

<div id="hpRows" class="hp-rows"></div>

