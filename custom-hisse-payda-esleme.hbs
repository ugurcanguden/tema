<a class="fab-item" href="/ipotek-doner-sermaye-hesaplama/"><span class="fab-lbl">İpotek Tesisi Masraf Hesaplama</span><span class="fab-dot"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L1.5 6.5h13L8 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><path d="M3.5 6.5V13M6 6.5V13M10 6.5V13M12.5 6.5V13" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M2 13h12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span></a>
</div>
<button class="fab-toggle" id="fabToggle" type="button" aria-label="Araçlar menüsü"><span class="fab-ti"><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2.5" y="2.5" width="5" height="5" rx="1" stroke="white" stroke-width="1.5"/><rect x="10.5" y="2.5" width="5" height="5" rx="1" stroke="white" stroke-width="1.5"/><rect x="2.5" y="10.5" width="5" height="5" rx="1" stroke="white" stroke-width="1.5"/><rect x="10.5" y="10.5" width="5" height="5" rx="1" stroke="white" stroke-width="1.5"/></svg></span></button>
</div>
<script>(function(){var t=document.getElementById('fabToggle'),i=document.getElementById('fabItems');t.addEventListener('click',function(){var o=i.classList.toggle('open');t.classList.toggle('open',o)});document.addEventListener('click',function(e){if(!document.getElementById('fabWrap').contains(e.target)){i.classList.remove('open');t.classList.remove('open')}})})();</script>

<script>
(function(){
'use strict';
var MAX_CD=100000000;
var rowCounter=0;

function gcd(a,b){while(b!==0){var t=b;b=a%b;a=t}return Math.abs(a)}
function lcm(a,b){return(Math.abs(a)/gcd(a,b))*Math.abs(b)}
function lcmAll(arr){return arr.reduce(function(acc,v){return lcm(acc,v)},1)}

function addRow(pv,pdv){
rowCounter++;
var div=document.createElement('div');
div.className='hp-row';
div.innerHTML=
'<span class="hp-row-num"></span>'+
'<div class="hp-frac">'+
'<div class="hp-frac-f"><span class="hp-frac-lbl">Pay</span>'+
'<input class="hp-frac-inp" type="number" min="1" step="1" placeholder="Örn: 1"'+(pv!==null&&pv!==''?' value="'+pv+'"':'')+'/></div>'+
'<span class="hp-frac-sep">/</span>'+
'<div class="hp-frac-f"><span class="hp-frac-lbl">Payda</span>'+
'<input class="hp-frac-inp" type="number" min="1" step="1" placeholder="Örn: 5"'+(pdv!==null&&pdv!==''?' value="'+pdv+'"':'')+'/></div>'+
'</div>'+
'<button class="hp-del" type="button" title="Sil">&#x2715;</button>';
div.querySelector('.hp-del').addEventListener('click',function(){
if(document.querySelectorAll('#hpRows .hp-row').length>1){div.remove();updateNums()}
else showErr('En az bir hisse satırı olmalıdır.');
});
div.querySelectorAll('.hp-frac-inp').forEach(function(inp){
inp.addEventListener('keydown',function(e){if(e.key==='Enter')calculate()});
});
document.getElementById('hpRows').appendChild(div);
updateNums();
}

function updateNums(){
document.querySelectorAll('#hpRows .hp-row').forEach(function(r,i){
var n=r.querySelector('.hp-row-num');
if(n)n.textContent=(i+1)+'.';
});
}

function getData(){
var shares=[];
document.querySelectorAll('#hpRows .hp-row').forEach(function(r){
var inp=r.querySelectorAll('.hp-frac-inp');
shares.push({pay:inp[0].value.trim(),payda:inp[1].value.trim()});
});
return shares;
}

function validate(shares){
if(shares.length===0)return'En az bir hisse girmelisiniz.';
for(var i=0;i<shares.length;i++){
var s=shares[i],n=i+1;
if(s.pay==='')return n+'. hisse: Pay alanı boş bırakılamaz.';
if(s.payda==='')return n+'. hisse: Payda alanı boş bırakılamaz.';
var pv=parseFloat(s.pay),pdv=parseFloat(s.payda);
if(isNaN(pv)||pv!==Math.floor(pv)||pv<=0)return n+'. hisse: Pay pozitif tam sayı olmalıdır.';
if(isNaN(pdv)||pdv!==Math.floor(pdv)||pdv<=0)return n+'. hisse: Payda pozitif tam sayı olmalıdır (0 olamaz).';
}
return null;
}

function calculate(){
clearErr();clearWarn();
var raw=getData();
var err=validate(raw);
if(err){showErr(err);return}
var shares=raw.map(function(s){return{pay:parseInt(s.pay,10),payda:parseInt(s.payda,10)}});
var denoms=shares.map(function(s){return s.payda});
var cd=lcmAll(denoms);
if(cd>MAX_CD)showWarn('Ortak payda çok büyük oluştu ('+cd.toLocaleString('tr-TR')+'). Lütfen hisseleri kontrol edin.');
var norm=shares.map(function(s){
var mult=cd/s.payda;
return{origPay:s.pay,origPayda:s.payda,newPay:s.pay*mult,newPayda:cd,mult:mult};
});
var totalPay=norm.reduce(function(a,n){return a+n.newPay},0);
renderResults(norm,cd,totalPay);
}

function renderResults(norm,cd,totalPay){
var h='';
h+='<div class="hp-card-title">Payda Eşitleme Sonucu</div>';
h+='<div class="hp-payda-box"><span class="hp-payda-lbl">Ortak Payda</span><span class="hp-payda-val">'+cd+'</span></div>';
h+='<table class="hp-tbl"><thead><tr>';
h+='<th>#</th><th>Girilen</th><th class="hp-col-pay">Pay</th><th class="hp-col-payda">Payda</th><th>Çarpan</th><th>Eşitlenmiş</th>';
h+='</tr></thead><tbody>';
norm.forEach(function(n,i){
h+='<tr>';
h+='<td class="hp-td-n">'+(i+1)+'</td>';
h+='<td class="hp-td-orig">'+n.origPay+'/'+n.origPayda+'</td>';
h+='<td class="hp-td-mono hp-col-pay">'+n.origPay+'</td>';
h+='<td class="hp-td-mono hp-col-payda">'+n.origPayda+'</td>';
h+='<td class="hp-td-x">&#215;'+n.mult+'</td>';
h+='<td class="hp-td-eq">'+n.newPay+'/'+n.newPayda+'</td>';
h+='</tr>';
});
h+='</tbody></table>';
var cls,msg;
if(totalPay===cd){
cls='hp-total-ok';
msg='Girilen hisselerin toplamı<br>tam hisseye eşittir.';
}else if(totalPay<cd){
cls='hp-total-low';
msg='Tam hisseyi tamamlamıyor.<br>Eksik: '+(cd-totalPay)+'/'+cd;
}else{
cls='hp-total-hi';
msg='Tam hisseden fazladır.<br>Fazla: '+(totalPay-cd)+'/'+cd;
}
h+='<div class="hp-total '+cls+'">';
h+='<div><div class="hp-total-sublbl">Toplam Hisse</div><div class="hp-total-frac">'+totalPay+'/'+cd+'</div></div>';
h+='<div class="hp-total-msg">'+msg+'</div>';
h+='</div>';
var res=document.getElementById('hpRes');
res.innerHTML=h;
res.classList.add('on');
document.getElementById('hpEmpty').style.display='none';
}

function resetAll(){
document.getElementById('hpRows').innerHTML='';
rowCounter=0;
addRow(null,null);addRow(null,null);
clearErr();clearWarn();
var res=document.getElementById('hpRes');
res.classList.remove('on');res.innerHTML='';
document.getElementById('hpEmpty').style.display='';
document.getElementById('hpQiInput').value='';
}

function parseQuickInput(){
var text=document.getElementById('hpQiInput').value.trim();
if(!text)return;
var parts=text.split(',');
var newShares=[];
for(var i=0;i<parts.length;i++){
var part=parts[i].trim();
var sl=part.split('/');
if(sl.length!==2||!sl[0].trim()||!sl[1].trim()||isNaN(sl[0].trim())||isNaN(sl[1].trim())){
showErr('Hisse formatı geçersiz. Lütfen 1/5, 2/4 gibi pay/payda formatında girin.');return;
}
newShares.push({pay:sl[0].trim(),payda:sl[1].trim()});
}
if(newShares.length===0){showErr('Hisse bulunamadı.');return}
document.getElementById('hpRows').innerHTML='';rowCounter=0;clearErr();
newShares.forEach(function(s){addRow(s.pay,s.payda)});
document.getElementById('hpQiInput').value='';
}

function showErr(m){document.getElementById('hpErrMsg').textContent=m;document.getElementById('hpErr').classList.add('on')}
function clearErr(){document.getElementById('hpErr').classList.remove('on')}
function showWarn(m){document.getElementById('hpWarnMsg').textContent=m;document.getElementById('hpWarn').classList.add('on')}
function clearWarn(){document.getElementById('hpWarn').classList.remove('on')}

document.getElementById('hpCalcBtn').addEventListener('click',calculate);
document.getElementById('hpClearBtn').addEventListener('click',resetAll);
document.getElementById('hpAddBtn').addEventListener('click',function(){addRow(null,null)});
document.getElementById('hpQiBtn').addEventListener('click',parseQuickInput);
document.getElementById('hpQiInput').addEventListener('keydown',function(e){if(e.key==='Enter')parseQuickInput()});

addRow(null,null);addRow(null,null);
})();
</script>
